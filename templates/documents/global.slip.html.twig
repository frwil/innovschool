<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-size: 12px;
            color: #343232;
        }
        @page {
            size: A4 landscape; /* Mode paysage */
            margin: 10mm; /* Ajuste les marges selon tes besoins */
        }

        .invoice-table {
            width: 297mm; /* Largeur de la page en mode paysage */
            margin: 0 auto;
            border-collapse: collapse;
            box-sizing: border-box;
            table-layout: fixed; /* Fixe la largeur des colonnes */
        }

        .invoice-table td {
            padding: 10px;
            border: 1px solid #343232;
            vertical-align: top;
            word-wrap: break-word; /* Permet de forcer le retour à la ligne si le texte est trop long */
        }

        .listTable td {
            padding: 7px;
        }

        .head-table td {
            padding: 2px;
        }

        .col-1 {
            width: 4.16%; /* 1/24 */
        }

        .col-2 {
            width: 8.33%; /* 2/24 */
        }

        .col-3 {
            width: 12.5%; /* 3/24 */
        }

        .col-4 {
            width: 16.66%; /* 4/24 */
        }

        .col-5 {
            width: 20.83%; /* 5/24 */
        }

        .col-6 {
            width: 25%; /* 6/24 */
        }

        .col-7 {
            width: 29.16%; /* 7/24 */
        }

        .col-8 {
            width: 33.33%; /* 8/24 */
        }

        .col-9 {
            width: 37.5%; /* 9/24 */
        }

        .col-10 {
            width: 41.66%; /* 10/24 */
        }

        .col-11 {
            width: 45.83%; /* 11/24 */
        }

        .col-12 {
            width: 50%; /* 12/24 */
        }

        .col-13 {
            width: 54.16%; /* 13/24 */
        }

        .col-14 {
            width: 58.33%; /* 14/24 */
        }

        .col-15 {
            width: 62.5%; /* 15/24 */
        }

        .col-16 {
            width: 66.66%; /* 16/24 */
        }

        .col-17 {
            width: 70.83%; /* 17/24 */
        }

        .col-18 {
            width: 75%; /* 18/24 */
        }

        .col-19 {
            width: 79.16%; /* 19/24 */
        }

        .col-20 {
            width: 83.33%; /* 20/24 */
        }

        .col-21 {
            width: 87.5%; /* 21/24 */
        }

        .col-22 {
            width: 91.66%; /* 22/24 */
        }

        .col-23 {
            width: 95.83%; /* 23/24 */
        }

        .col-24 {
            width: 100%; /* 24/24 */
        }

        .header,
        .footer,
        .invoice-details,
        .totals,
        .signature {
            padding: 0;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            text-align: center;
        }

        .header p,
        .footer p {
            margin: 0;
            text-align: center;
            font-size: 12px;
        }

        .invoice-details table {
            width: 100%;
            border-collapse: collapse;
        }

        .invoice-details th,
        .invoice-details td {
            padding: 10px;
            border: 1px solid #000;
            text-align: left;
        }

        .invoice-details th {
            background-color: #f2f2f2;
        }

        .totals {
            text-align: right;
        }

        .totals table {
            width: 100%;
            border-collapse: collapse;
        }

        .totals th,
        .totals td {
            padding: 10px;
            border: 1px solid #000;
        }

        .totals th {
            background-color: #f2f2f2;
        }

        .signature {
            text-align: right;
            font-size: 14px;
        }

        .objectRaw p {
            margin-top: 0px;
            margin-bottom: auto;
        }
    </style>
</head>

<body>
    <table class="invoice-table">
        <tr>
            <td colspan="24" class="col-24" style="border: 0px; text-align: center;">
                EN TETE
            </td>
        </tr>
        <tr>
            <td colspan="24" class="col-24" style="border: 0px; text-align: center;">
                RELEVE DE NOTE
            </td>
        </tr>
       
        <tr>
            <td colspan="24" class="col-24" style="border: 0px; text-align: center;">
                
            </td>
        </tr>
        <tr>
            <td colspan="1" class="col-1"></td>
            <td colspan="4" class="col-4"></td>
            {% for subject in model.subjects %}
            <td colspan="1" class="col-1" style="text-align: center; writing-mode: sideways-lr; ">{{ subject }}</td>
            {% endfor %}
        </tr>
        <tr>
            <td colspan="1" class="col-1">
                N<sup>o</sup>
            </td>
            <td colspan="4" class="col-4">
                Coéfficient
            </td>
            {% for subject in model.subjects %}
            <td colspan="1" class="col-1"> {{ subject.coefficient }} </td>
            {% endfor %}
        </tr>
        {% for student in model.students %}
        <tr>
            <td colspan="1" class="col-1">
                {{ loop.index }}
            </td>
            <td colspan="4" class="col-4">
                {{ student.fullName }}
            </td>
            {% for subject in model.subjects %}
            <td colspan="1" class="col-1"></td>
            {% endfor %}
        </tr>
        {% endfor %}
    </table>
</body>

</html>