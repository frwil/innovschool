      const action = $row.find('.select-reportcard-action').val();
      const classId = $(this).data('class-id');
      const templateId = $(this).data('template-id');

      if (action === 'edit-template') {
        if (!templateId) {
          $.notify('Aucun modèle de bulletin à modifier pour cette classe.', 'info');
          return;
        }
        // Ouvre la modale de modification du modèle
        $.ajax({
          url: '{{ path("app_get_reportcard_template", { id: "TEMPLATE_ID" }) }}'.replace('TEMPLATE_ID', templateId),
          method: 'GET',
