            $('#editTemplateId').val(data.id);
            $('#editTemplateName').val(data.name);
            $('#editTemplateDescription').val(data.description);
            $('#editTemplateHeaderTitle').val(data.headerTitle);
            $('#editTemplateHeaderLeft').val(data.headerLeft);
            $('#editTemplateHeaderRight').val(data.headerRight);
            $('#editTemplateNationalMottoLeft').val(data.nationalMottoLeft);
            $('#editTemplateNationalMottoRight').val(data.nationalMottoRight);
            $('#editReportCardTemplateModal').modal('show');
          },
          error: function () {
            $.notify('Erreur lors du chargement du modèle.', 'error');
          }
        });
      } else if (action === 'edit-assignment') {
        // Ouvre la modale de modification d'affectation
        const rowData = $('#reportcard-classes-table').DataTable().row($(this).parents('tr')).data();
        $('#editAssignmentClassId').val(classId);
        $('#editAssignmentTemplateId').val(rowData.templateId);
        $('#editReportCardAssignmentModal').modal('show');
      }
    });

    // Mise à jour dynamique des classes selon la section
    $('#sectionSelect').on('change', function () {
      const sectionId = $(this).val();
      const classSelect = $('#classSelect');
      classSelect.empty()
      if(sectionId && sectionId !='') classSelect.append(new Option('Chargement en cours...', ''));
      if (sectionId) {
        $.ajax({
          url: '{{ path("app_classes_by_section") }}',
          method: 'GET',
          data: { sectionId: sectionId },
          success: function (data) {
            classSelect.empty().append(new Option('Sélectionner une classe', ''));
            data.forEach(function (classItem) {
              classSelect.append(new Option(classItem.name, classItem.id));
            });
          },
          error: function () {
            $.notify('Erreur lors du chargement des classes.', 'error');
          }
        });
      }
    });

    // Soumission du formulaire d'affectation
    $('#assign-reportcard-form').on('submit', function (e) {
      e.preventDefault();
      const formData = {
        classId: $('#classSelect').val(),
        templateId: $('#templateSelect').val()
      };
      $.ajax({
        url: '{{ path("app_assign_reportcard_template") }}',
        method: 'POST',
        data: formData,
        success: function () {
          $.notify('Modèle de bulletin assigné avec succès.', 'success');
          $('#reportcard-classes-table').DataTable().ajax.reload();
          $('#assign-reportcard-form')[0].reset();
          $('#sectionSelect, #classSelect, #templateSelect').val(null).trigger('change');
        },
        error: function () {
          $.notify('Erreur lors de l\'assignation.', 'error');
        }
      });
    });

    // Gestion des boutons Modifier/Supprimer à compléter selon tes routes
    $('#reportcard-classes-table').on('click', '.delete-reportcard', function () {
      const classId = $(this).data('id');
      if (confirm('Supprimer l\'affectation du modèle de bulletin pour cette classe ?')) {
        $.ajax({
          url: '{{ path("app_remove_reportcard_template_from_class", { id: "ID" }) }}'.replace('ID', classId),
          method: 'DELETE',
          success: function (response) {
            $.notify(response.message ? response.message : 'Affectation retirée de la classe avec succès', 'success');
            $('#reportcard-classes-table').DataTable().ajax.reload();
          },
          error: function () {
            $.notify('Erreur lors de la suppression.', 'error');
          }
        });
      }
    });

    $('#reportcard-classes-table').on('click', '.edit-reportcard-template', function (e) {
      e.preventDefault();
      const templateId = $(this).data('id');
      if (!templateId) {
        $.notify('Aucun modèle de bulletin à modifier pour cette classe.', 'info');
        return;
      }
      $.ajax({
        url: '{{ path("app_get_reportcard_template", { id: "TEMPLATE_ID" }) }}'.replace('TEMPLATE_ID', templateId),
        method: 'GET',
        success: function (data) {
          $('#editTemplateId').val(data.id);
          $('#editTemplateName').val(data.name);
          $('#editTemplateDescription').val(data.description);
          $('#editTemplateHeaderTitle').val(data.headerTitle);
          $('#editTemplateHeaderLeft').val(data.headerLeft);
          $('#editTemplateHeaderRight').val(data.headerRight);
          $('#editTemplateNationalMottoLeft').val(data.nationalMottoLeft);
          $('#editTemplateNationalMottoRight').val(data.nationalMottoRight);
          $('#editReportCardTemplateModal').modal('show');
        },
        error: function () {
          $.notify('Erreur lors du chargement du modèle.', 'error');
        }
      });
    });

    $('#reportcard-classes-table').on('click', '.edit-reportcard', function (e) {
      e.preventDefault();
      const classId = $(this).data('id');
      // Récupère la ligne du DataTable
      const rowData = $('#reportcard-classes-table').DataTable().row($(this).parents('tr')).data();
      $('#editAssignmentClassId').val(classId);
      $('#editAssignmentTemplateId').val(rowData.templateId);
      $('#editReportCardAssignmentModal').modal('show');
    });

    // Soumission du formulaire de modification d'affectation
    $('#edit-reportcard-assignment-form').on('submit', function (e) {
      e.preventDefault();
      const formData = {
        classId: [$('#editAssignmentClassId').val()],
        templateId: $('#editAssignmentTemplateId').val()
      };
      $.ajax({
        url: '{{ path("app_assign_reportcard_template") }}',
        method: 'POST',
        data: formData,
        success: function () {
          $.notify('Affectation modifiée avec succès.', 'success');
          $('#editReportCardAssignmentModal').modal('hide');
          $('#reportcard-classes-table').DataTable().ajax.reload();
        },
        error: function () {
          $.notify('Erreur lors de la modification de l\'affectation.', 'error');
        }
      });
    });

    $('#edit-reportcard-template-form').on('submit', function (e) {
      e.preventDefault();
      const formData = {
        name: $('#editTemplateName').val(),
        description: $('#editTemplateDescription').val(),
        headerTitle: $('#editTemplateHeaderTitle').val(),
        headerLeft: $('#editTemplateHeaderLeft').val(),
        headerRight: $('#editTemplateHeaderRight').val(),
        nationalMottoLeft: $('#editTemplateNationalMottoLeft').val(),
        nationalMottoRight: $('#editTemplateNationalMottoRight').val()
      };
      const templateId = $('#editTemplateId').val();
      $.ajax({
        url: '{{ path("app_edit_reportcard_template", { id: "TEMPLATE_ID" }) }}'.replace('TEMPLATE_ID', templateId),
        method: 'POST',
        data: formData,
        success: function () {
          $.notify('Modèle modifié avec succès.', 'success');
          $('#editReportCardTemplateModal').modal('hide');
          $('#reportcard-classes-table').DataTable().ajax.reload();
        },
        error: function () {
          $.notify('Erreur lors de la modification du modèle.', 'error');
        }
      });
    });

    $('#sectionId-aff').on('change', function () {
      const sectionId = $(this).val();
      const classSelect = $('#classId-aff');
      classSelect.empty()
      $('#assigned-subjects-table').DataTable().clear().draw();
      if(sectionId && sectionId !='') {
        classSelect.append(new Option('Chargement en cours...', ''));
        $('#sp-classId-aff').addClass('spinner-border');
        $('#sp-classId-aff-text').html('Chargement en cours...');
      }
      classSelect.prop('disabled', true); // Désactiver le sélecteur de classe
      $('#showAssignedSubjectsBtn').prop('disabled', true); // Désactiver le bouton de chargement des classes
      if (sectionId) {
        $.ajax({
          url: '{{ path("app_generic_classes_by_section") }}',
          method: 'GET',
          data: { sectionId: sectionId },
          success: function (data) {
            classSelect.empty().append(new Option('Sélectionner une classe', ''));
            data.forEach(function (classItem) {
              classSelect.append(new Option(classItem.name, classItem.id));
            });
            classSelect.prop('disabled', false); // Activer le sélecteur de classe
            $('#sp-classId-aff').removeClass('spinner-border');
            $('#sp-classId-aff-text').html('');
          },
          error: function () {
            $.notify('Erreur lors du chargement des classes.', 'error');
            $('#sp-classId-aff').removeClass('spinner-border');
            $('#sp-classId-aff-text').html('');
          }
        });
      }
    });

    $('#classId-aff').on('change', function () {
      const classId = $(this).val();
      $('#sp-classId-aff').addClass('spinner-border');
      $('#sp-classId-aff-text').html('Chargement en cours...');
      if (classId) {
        $('#showAssignedSubjectsBtn').prop('disabled', false); // Activer le bouton de chargement des classes
      } else {
        $('#showAssignedSubjectsBtn').prop('disabled', true); // Désactiver le bouton si aucune classe n'est sélectionnée
      }
      //logique pour charger les matières si nécessaire dans le datatable
      if (classId != '') {
        $('#assigned-subjects-table').DataTable().clear().draw();
        $('#assigned-subjects-table').DataTable().ajax.url('{{ path("app_get_assigned_subjects_by_class", { id: "ID" }) }}'.replace('ID', classId));
        $('#assigned-subjects-table').DataTable().ajax.reload(()=>{
          $('#sp-classId-aff').removeClass('spinner-border');
          $('#sp-classId-aff-text').html('');
        });
        //
        
      }
    });

    $('#assigned-subjects-table').DataTable({
      "ajax": {
        "url": "",
        "dataSrc": ""
      },
      columns: [
        { data: 'classe', title: 'Classe' },
        { data: 'name', title: 'Matière' },
        { data: 'coefficient', title: 'Coefficient' },
        {
          data: 'null', title: 'Groupe', render: function (data, type, row) {
            return row.group ? `${row.group}&nbsp;<button class="btn btn-sm btn-danger cancel-subject-group" style="padding:5px !important;font-size:10px !important" data-id="${row.id}" title="Annuler l'affectation à cette matière"><i class="fa fa-trash"></i></button>` : '';
          }
        },
        {
          data: 'null', title: 'Enseignant', render: function (data, type, row) {
            return row.teacher ? `${row.teacher}&nbsp;<button class="btn btn-sm btn-danger cancel-subject-teacher" style="padding:5px !important;font-size:10px !important" data-id="${row.id}" title="Annuler l'affectation à cette matière"><i class="fa fa-trash"></i></button>` : '';
          }
        },
        { data: 'skills', title: 'Compétences' },
        {
          data: null,
          render: function (data, type, row) {
            return `
                    <button class="btn btn-sm btn-primary edit-subject" data-id="${row.id}" title="Modifier"><i class="fa fa-pencil-alt"></i></button>
                    <button class="btn btn-sm btn-danger delete-subject" data-id="${row.id}" title="Supprimer"><i class="fa fa-trash"></i></button>
                `;
          },
          title: 'Actions'
        }
      ],
      language: {
        url: "{{asset('i18n/fr-FR.json')}}"
      },
      searching: true,
      paging: false,
      info: false
    });
    $('#assigned-subjects-table').on('click', '.delete-subject', function () {
      const subjectId = $(this).data('id');
      if (confirm('Voulez-vous vraiment supprimer cette matière affectée ?')) {
        $.ajax({
          url: '{{ path("app_delete_assigned_subject", { id: "ID" }) }}'.replace('ID', subjectId), // Remplace par ta route Symfony
          method: 'DELETE',
          success: function () {
            $.notify('Matière supprimée avec succès.', 'success');
            $('#assigned-subjects-table').DataTable().ajax.reload();
          },
          error: function () {
            $.notify('Erreur lors de la suppression.', 'error');
          }
        });
      }
    });

    $('#assigned-subjects-table').on('click', '.edit-subject', function () {
      const rowData = $('#assigned-subjects-table').DataTable().row($(this).parents('tr')).data();
      $('#editSubjectAssignmentId').val(rowData.id);
      $('#editSubjectCoefficient').val(rowData.coefficient);
      $('#editSubjectGroup').val(rowData.group_id).trigger('change');
      $('#editSubjectTeacher').val(rowData.teacher_id).trigger('change');
      $('#editSubjectSkills').val(rowData.skills);
      $('#editSubjectAssignmentModal').modal('show');
    });

    $('#edit-subject-assignment-form').on('submit', function (e) {
      e.preventDefault();
      const formData = {
        id: $('#editSubjectAssignmentId').val(),
        coefficient: $('#editSubjectCoefficient').val(),
        group: $('#editSubjectGroup').val(),
        teacher: $('#editSubjectTeacher').val(),
        skills: $('#editSubjectSkills').val(),
        assignTeacherMethod: $('#assignTeacherMethod').val()
      };
      $.ajax({
        url: '{{ path("app_edit_subject_assignment",{id:"ID"}) }}'.replace('ID', $('#editSubjectAssignmentId').val()), // À créer côté Symfony
        method: 'POST',
        data: formData,
        success: function () {
          $.notify('Assignation modifiée avec succès.', 'success');
          $('#editSubjectAssignmentModal').modal('hide');
          const classId = $('#classId-aff').val();
          // Recharge le DataTable des matières assignées
          $('#assigned-subjects-table').DataTable().ajax.url('{{ path("app_get_assigned_subjects_by_class", { id: "ID" }) }}'.replace('ID', classId)).load();
        },
        error: function () {
          $.notify('Erreur lors de la modification.', 'error');
        }
      });
    });

    $('#assigned-subjects-table').on('click', '.cancel-subject-group', function () {
      const subjectId = $(this).data('id');
      if (confirm('Voulez-vous vraiment annuler l\'affectation de ce groupe à la matière ?')) {
        $.ajax({
          url: '{{ path("app_cancel_subject_group") }}', // Crée cette route côté Symfony
          method: 'POST',
          data: {
            id: subjectId,
            _token: '{{ csrf_token("cancel_subject_group") }}'
          },
          success: function () {
            $.notify('Affectation du groupe annulée.', 'success');
            $('#assigned-subjects-table').DataTable().ajax.reload();
          },
          error: function () {
            $.notify('Erreur lors de l\'annulation.', 'error');
          }
        });
      }
    });

    $('#assigned-subjects-table').on('click', '.cancel-subject-teacher', function () {
      const subjectId = $(this).data('id');
      if (confirm('Voulez-vous vraiment annuler l\'affectation de cet enseignant à la matière ?')) {
        $.ajax({
          url: '{{ path("app_cancel_subject_teacher") }}', // Crée cette route côté Symfony
          method: 'POST',
          data: {
            id: subjectId,
            _token: '{{ csrf_token("cancel_subject_teacher") }}'
          },
          success: function () {
            $.notify('Affectation de l\'enseignant annulée.', 'success');
            $('#assigned-subjects-table').DataTable().ajax.reload();
          },
          error: function () {
            $.notify('Erreur lors de l\'annulation.', 'error');
          }
        });
      }
    });

    $('#selectAllClasses').on('click', function () {
      if ($('#classId').find('option:selected').length > 0) {
        $('#classId').val(null).trigger('change');
        $('#selectAllClasses').html('Sélectionner Tout');
      } else {
        $('#classId').find('option').prop('selected', true).trigger('change');
        if ($('#classId').find('option:selected').length > 0) $('#selectAllClasses').html('Désélectionner Tout');
      }
    })
});
</script>
{% endblock %}