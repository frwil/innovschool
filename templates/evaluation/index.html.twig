{% extends 'base.up.html.twig' %} {% block title %}Gestion des évaluations {%
endblock %} {% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/rowGroup.dataTables.css') }}" />
{% endblock %} {% block body %}
<div class="container mt-4">
  <div class="three">
    <h1 class="mb-4">Gestion des évaluations</h1>
  </div>

  <!-- Onglets -->
  <ul class="nav nav-tabs" id="evaluationTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="base-config-tab" data-bs-toggle="tab" data-bs-target="#base-config"
        type="button" role="tab" aria-controls="base-config" aria-selected="true">
        Configuration de base
      </button>
    </li>
    <!-- Nouvel onglet Matières affectées -->
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="assigned-subjects-tab" data-bs-toggle="tab" data-bs-target="#assigned-subjects"
        type="button" role="tab" aria-controls="assigned-subjects" aria-selected="false">
        Matières affectées
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="evaluation-modules-tab" data-bs-toggle="tab" data-bs-target="#evaluation-modules"
        type="button" role="tab" aria-controls="evaluation-modules" aria-selected="false">
        Modules d'évaluation
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="appreciations-tab" data-bs-toggle="tab" data-bs-target="#appreciations" type="button"
        role="tab" aria-controls="appreciations" aria-selected="false">
        Appréciations
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="type-bulletins-tab" data-bs-toggle="tab" data-bs-target="#typebulletins"
        type="button" role="tab" aria-controls="typebulletins" aria-selected="false">
        Type de bulletins
      </button>
    </li>
  </ul>

  <div class="tab-content mt-4" id="evaluationTabsContent">
    <!-- Onglet 1 : Configuration de base -->
    <div class="tab-pane fade show active" id="base-config" role="tabpanel" aria-labelledby="base-config-tab">
      <div class="row mb-3">
        <div class="col-md-6">
          <!-- Bloc 1 : DataTable avec la liste des évaluations -->
          <div class="card mb-4">
            <div class="card-header">Liste des évaluations</div>
            <div class="card-body">
              <table id="evaluations-table" class="table table-bordered">
                <thead>
                  <tr>
                    <th>Classe</th>
                    <th>Période</th>
                    <th>Sous-période</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Les données seront chargées dynamiquement via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <!-- Bloc 2 : Formulaire de création d'une évaluation -->
          <div class="card mb-4">
            <div class="card-header">Créer une nouvelle évaluation</div>
            <div class="card-body">
              <form id="create-evaluation-form">
                <div class="row">
                  <!-- Colonne gauche -->
                  <div class="col-md-6">
                    <!-- Champ pour les niveaux d'étude -->
                    <div class="mb-3">
                      <label for="sectionId" class="form-label">Niveau d'étude</label>
                      <select id="sectionId" name="sectionId" class="form-select select2">
                        <option></option>
                        <!-- Options dynamiques -->
                        {% for section in sections %}
                        <option value="{{ section.id }}">
                          {{ section.name }}
                        </option>
                        {% endfor %}
                      </select>
                    </div>

                    <!-- Champ pour les classes -->
                    <div class="mb-3">
                      <label for="classId" class="form-label">Classe</label>
                      <select id="classId" name="classId[]" class="form-select select2" multiple>
                        <!-- Options dynamiques (chargées via JavaScript) -->
                      </select>
                      <button type="button" id="selectAllClasses" class="btn btn-light">Sélectionner Tout</button>
                      <span id="classId-loading" style="display: block;"></span>
                    </div>
                  </div>

                  <!-- Colonne droite -->
                  <div class="col-md-6">
                    <!-- Champ pour les périodes d'évaluation -->
                    <div class="mb-3">
                      <label for="evaluationFrameId" class="form-label">Période d'évaluation</label>
                      <select id="evaluationFrameId" name="evaluationFrameId" class="form-select select2">
                        <option></option>
                        <!-- Options dynamiques depuis la table evaluationFrames -->
                        <!-- Options dynamiques -->
                        {% for frame in evaluationFrames %}
                        <option value="{{ frame.id }}">{{ frame.name }}</option>
                        {% endfor %}
                      </select>
                    </div>

                    <!-- Champ pour les périodicités -->
                    <div class="mb-3">
                      <label for="evaluationTimeTypeId" class="form-label">Périodicité</label>
                      <select id="evaluationTimeTypeId" name="evaluationTimeTypeId" class="form-select select2">
                        <option></option>
                        <!-- Options dynamiques depuis la table schoolEvaluationTimeType -->
                        {% for type in evaluationTimeTypes %}
                        <option value="{{ type.id }}">{{ type.name }}</option>
                        {% endfor %}
                      </select>
                    </div>

                    <!-- Champ pour les sous-périodes d'évaluation -->
                    <div class="mb-3">
                      <label for="evaluationTimeId" class="form-label">Sous-période d'évaluation</label>
                      <select id="evaluationTimeId" name="evaluationTimeId" class="form-select select2">
                        <!-- Options dynamiques -->
                      </select>
                    </div>
                  </div>
                </div>

                <!-- Bouton de soumission -->
                <button type="submit" class="btn btn-primary" id="bntSaveEvaluation">Créer</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Onglet 2 : Matières affectées -->
    <div class="tab-pane fade" id="assigned-subjects" role="tabpanel" aria-labelledby="assigned-subjects-tab">
      <div class="row">
        <div class="col-md-12">
          <div class="card">
            <div class="card-header">Liste des matières affectées</div>
            <div class="card-body">
              <form method="post" action="" id="show-assign-subjects-form">
                <div class="row">
                  <div class="mb-3 col-md-3">
                    <label for="sectionId" class="form-label">Niveau d'étude</label>
                    <select id="sectionId-aff" name="sectionId-aff" class="form-select select2">
                      <option value="">Sélectionner un niveau</option>
                      {% for section in sections %}
                      <option value="{{ section.id }}">{{ section.name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="mb-3 col-md-3">
                    <label for="classId-aff" class="form-label">Classe</label>
                    <select id="classId-aff" name="classId-aff" class="form-select select2" disabled>
                      <option value="">Sélectionner une classe</option>
                      <!-- Options dynamiques via JS -->
                    </select>
                    <span id="sp-classId-aff"></span><span id="sp-classId-aff-text"></span>
                  </div>
                </div>
              </form>
              <table id="assigned-subjects-table" class="table table-bordered">
                <thead>
                  <tr>
                    <th>Classe</th>
                    <th>Matière</th>
                    <th>Coefficient</th>
                    <th>Groupe</th>
                    <th>Enseignant</th>
                    <th>Compétences</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Les données seront chargées dynamiquement via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Onglet 3 : Modules d'évaluation -->
    <div class="tab-pane fade" id="evaluation-modules" role="tabpanel" aria-labelledby="evaluation-modules-tab">
      <div class="row">
        <!-- Bloc 1 : DataTable (70%) -->
        <div class="col-md-8">
          <div class="card">
            <div class="card-header">Liste des modules d'évaluation</div>
            <div class="card-body">
              <table id="modules-table" class="table table-bordered">
                <thead>
                  <tr>
                    <th>Matière</th>
                    <th>Classe</th>
                    <th>Module</th>
                    <th>Notation</th>
                    <th>Évaluations</th>
                    <!-- Nouvelle colonne -->
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Les données seront chargées dynamiquement via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Bloc 2 : Formulaire (30%) -->
        <div class="col-md-4">
          <div class="card">
            <div class="card-header">Module Mapping</div>
            <div class="card-body">
              <form id="create-module-form">
                <!-- Champ pour les niveaux d'étude -->
                <div class="mb-3">
                  <label for="sectionModuleId" class="form-label">Niveau d'étude</label>
                  <select id="sectionModuleId" name="sectionModuleId" class="form-select select2">
                    {% for section in sections %}
                    <option value="{{ section.id }}">{{ section.name }}</option>
                    {% endfor %}
                  </select>
                </div>

                <!-- Champ pour les classes -->
                <div class="mb-3">
                  <label for="classModuleId" class="form-label">Classe</label>
                  <select id="classModuleId" name="classModuleId" class="form-select select2">
                    <!-- Options dynamiques -->
                  </select>
                </div>

                <!-- Champ pour les matières -->
                <div class="mb-3">
                  <label for="subjectModuleId" class="form-label">Matière</label>
                  <div class="input-group">
                    <select id="subjectModuleId" name="subjectModuleId" class="form-select select2" multiple></select>
                    <button type="button" class="btn btn-light" id="selectAllBtn">
                      Sélectionner Tout
                    </button>
                  </div>
                </div>

                <!-- Champ pour le module -->
                <div class="form-group">
                  <label for="moduleName" class="form-label">Type de module</label>
                  <div class="input-group">
                    <select id="moduleName" name="moduleName" class="form-select">
                      <option></option>
                      <!-- Options dynamiques depuis la table subjectModules -->
                      {% for module in subjectModules %}
                      <option value="{{ module.id }}">
                        {{ module.moduleName }}
                      </option>
                      {% endfor %}
                    </select>
                    <button type="button" class="btn btn-secondary" data-bs-toggle="modal"
                      data-bs-target="#addModuleModal">
                      Ajouter un module
                    </button>
                  </div>
                </div>

                <!-- Champ pour la notation -->
                <div class="mb-3">
                  <label for="moduleNotation" class="form-label">Notation</label>
                  <input type="number" id="moduleNotation" name="moduleNotation" class="form-control" min="0"
                    value="20" />
                  <span class="text-muted">
                    <i>Note maximale pour le module</i>
                  </span>
                </div>

                <button type="submit" class="btn btn-primary" id="btn-create-module">Créer</button>
              </form>
              <!-- Fenêtre modale pour ajouter un module -->
              <div class="modal fade" id="addModuleModal" tabindex="-1" aria-labelledby="addModuleModalLabel"
                aria-hidden="true">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title" id="addModuleModalLabel">
                        Ajouter un module
                      </h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      <form id="add-module-form" method="POST" class="form-group">
                        <!-- Champ pour le nom du module -->
                        <div class="mb-3">
                          <label for="newModuleName" class="form-label">Nom du module</label>
                          <input type="text" id="newModuleName" name="newModuleName" class="form-control" required />
                        </div>
                        <!-- Champ pour la description du module -->
                        <div class="mb-3">
                          <label for="newModuleDescription" class="form-label">Description</label>
                          <textarea id="newModuleDescription" name="newModuleDescription" class="form-control"
                            rows="3"></textarea>
                        </div>
                        <button type="button" id="btn-submit-module" class="btn btn-primary">
                          Enregistrer
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Fenêtre modale pour modifier un module -->
              <div class="modal fade" id="editModuleModal" tabindex="-1" aria-labelledby="editModuleModalLabel"
                aria-hidden="true">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title" id="editModuleModalLabel">
                        Modifier le module
                      </h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      <form id="edit-module-form">
                        <div class="mb-3">
                          <label for="moduleNotationModal" class="form-label">Notation</label>
                          <input type="number" step="0.5" id="moduleNotationModal" name="moduleNotation"
                            class="form-control" min="0" required />
                        </div>
                        <button type="submit" class="btn btn-primary">
                          Enregistrer
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="appreciations" role="tabpanel" aria-labelledby="appreciations-tab">
      <div class="card">
        <div class="card-header">Gestion des appréciations</div>
        <div class="card-body">
          <!-- Ajoutez ici votre table, formulaire ou autre contenu pour gérer les appréciations -->
          <div class="row">
            <!-- Bloc 1 : DataTable (70%) -->
            <div class="col-md-8">
              <div class="card">
                <div class="card-header">Liste des barèmes</div>
                <div class="card-body">
                  <table id="baremes-table" class="table table-bordered">
                    <thead>
                      <tr>
                        <th>Template</th>
                        <th>Note maximale</th>
                        <th>Valeur abrégée</th>
                        <th>Valeur d'appréciation</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <!-- Les données seront chargées dynamiquement via AJAX -->
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            <!-- Bloc 2 : Formulaire (30%) -->
            <div class="col-md-4">
              <div class="card" style="height: auto !important">
                <div class="card-header">Créer un template d'appréciation</div>
                <div class="card-body">
                  <form id="create-template-form">
                    <div class="mb-3">
                      <label for="templateName" class="form-label">Nom du template</label>
                      <input type="text" id="templateName" name="templateName" class="form-control" required />
                    </div>
                    <div class="mb-3 form-check">
                      <input type="checkbox" class="form-check-input" id="templateDefault" name="templateDefault" />
                      <label class="form-check-label" for="templateDefault">Défaut</label>
                    </div>
                    <button type="submit" class="btn btn-primary">Créer</button>
                  </form>
                </div>
              </div>
              <div class="card" style="height: auto !important">
                <div class="card-header">Créer un barême d'appréciation</div>
                <div class="card-body">
                  <!-- Formulaire de création de barème -->
                  <form id="create-bareme-form" class="mt-4">
                    <div class="mb-3">
                      <label for="baremeTemplate" class="form-label">Template d'appréciation</label>
                      <select id="baremeTemplate" name="baremeTemplate" class="form-select select2" required>
                        <option value="">Sélectionner un template</option>
                        {% for template in appreciationTemplates %}
                        <option value="{{ template.id }}">
                          {{ template.name }}
                        </option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="mb-3">
                      <label for="baremeMaxNote" class="form-label">Note maximale</label>
                      <input type="number" id="baremeMaxNote" name="baremeMaxNote" class="form-control" min="0"
                        required />
                    </div>
                    <div class="mb-3">
                      <label for="baremeValue" class="form-label">Valeur abrégée</label>
                      <input type="text" id="baremeValue" name="baremeValue" class="form-control" required />
                    </div>
                    <div class="mb-3">
                      <label for="baremeFullValue" class="form-label">Valeur d'appréciation</label>
                      <input type="text" id="baremeFullValue" name="baremeFullValue" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-success">
                      Ajouter un barème
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="tab-pane fade" id="typebulletins" role="tabpanel" aria-labelledby="type-bulletins-tab">
      <div class="row">
        <!-- Bloc 1 : DataTable -->
        <div class="col-md-8">
          <div class="card">
            <div class="card-header">
              Affectation des modèles de bulletin aux classes
            </div>
            <div class="card-body">
              <table id="reportcard-classes-table" class="table table-bordered">
                <thead>
                  <tr>
                    <th>Classe</th>
                    <th>Modèle de bulletin</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Rempli dynamiquement via AJAX -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <!-- Bloc 2 : Formulaire d'affectation -->
        <div class="col-md-4">
          <div class="card">
            <div class="card-header">
              Assigner un modèle de bulletin à une classe
            </div>
            <div class="card-body">
              <form id="assign-reportcard-form">
                <div class="mb-3">
                  <label for="sectionSelect" class="form-label">Niveau d'étude</label>
                  <select id="sectionSelect" name="sectionId" class="form-select select2" required>
                    <option value="">Sélectionner un niveau</option>
                    {% for section in sections %}
                    <option value="{{ section.id }}">{{ section.name }}</option>
                    {% endfor %}
                  </select>
                </div>
                <div class="mb-3">
                  <label for="classSelect" class="form-label">Classe</label>
                  <select id="classSelect" name="classId[]" class="form-select select2" required multiple>
                    <option value="">Sélectionner une classe</option>
                    <!-- Options dynamiques via JS -->
                  </select>
                </div>
                <div class="mb-3">
                  <label for="templateSelect" class="form-label">Modèle de bulletin</label>
                  <select id="templateSelect" name="templateId" class="form-select select2" required>
                    <option value="">Sélectionner un modèle</option>
                    {% for template in reportCardTemplates %}
                    <option value="{{ template.id }}">
                      {{ template.name }}
                    </option>
                    {% endfor %}
                  </select>
                </div>
                <button type="submit" class="btn btn-success">Assigner</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Fenêtre modale pour modifier un modèle de bulletin -->
  <div class="modal fade" id="editReportCardTemplateModal" tabindex="-1"
    aria-labelledby="editReportCardTemplateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editReportCardTemplateModalLabel">Modifier le modèle de bulletin</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
        </div>
        <div class="modal-body">
          <form id="edit-reportcard-template-form">
            <input type="hidden" id="editTemplateId" name="templateId">
            <div class="mb-3">
              <label for="editTemplateName" class="form-label">Nom</label>
              <input type="text" class="form-control" id="editTemplateName" name="name" required>
            </div>
            <div class="mb-3">
              <label for="editTemplateDescription" class="form-label">Description</label>
              <textarea class="form-control" id="editTemplateDescription" name="description"></textarea>
            </div>
            <!-- Ajoute d'autres champs si besoin -->
            <div class="mb-3">
              <label for="editTemplateHeaderTitle" class="form-label">Titre d'en-tête</label>
              <input type="text" class="form-control" id="editTemplateHeaderTitle" name="headerTitle">
            </div>
            <div class="mb-3">
              <label for="editTemplateHeaderLeft" class="form-label">En-tête gauche</label>
              <textarea class="form-control" id="editTemplateHeaderLeft" name="headerLeft"></textarea>
            </div>
            <div class="mb-3">
              <label for="editTemplateHeaderRight" class="form-label">En-tête droite</label>
              <textarea class="form-control" id="editTemplateHeaderRight" name="headerRight"></textarea>
            </div>
            <div class="mb-3">
              <label for="editTemplateNationalMottoLeft" class="form-label">Devise nationale gauche</label>
              <input type="text" class="form-control" id="editTemplateNationalMottoLeft" name="nationalMottoLeft">
            </div>
            <div class="mb-3">
              <label for="editTemplateNationalMottoRight" class="form-label">Devise nationale droite</label>
              <input type="text" class="form-control" id="editTemplateNationalMottoRight" name="nationalMottoRight">
            </div>
            <button type="submit" class="btn btn-primary">Enregistrer</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Fenêtre modale pour modifier l'affectation du modèle de bulletin -->
  <div class="modal fade" id="editReportCardAssignmentModal" tabindex="-1"
    aria-labelledby="editReportCardAssignmentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editReportCardAssignmentModalLabel">Modifier l'affectation du modèle de bulletin
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
        </div>
        <div class="modal-body">
          <form id="edit-reportcard-assignment-form">
            <input type="hidden" id="editAssignmentClassId" name="classId">
            <div class="mb-3">
              <label for="editAssignmentTemplateId" class="form-label">Modèle de bulletin</label>
              <select id="editAssignmentTemplateId" name="templateId" class="form-select" required>
                <option value="">Sélectionner un modèle</option>
                {% for template in reportCardTemplates %}
                <option value="{{ template.id }}">{{ template.name }}</option>
                {% endfor %}
              </select>
            </div>
            <button type="submit" class="btn btn-primary">Enregistrer</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal de modification d'assignation de matière -->
  <div class="modal fade" id="editSubjectAssignmentModal" tabindex="-1"
    aria-labelledby="editSubjectAssignmentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <form id="edit-subject-assignment-form">
          <div class="modal-header">
            <h5 class="modal-title" id="editSubjectAssignmentModalLabel">Modifier l'assignation de matière</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" id="editSubjectAssignmentId" name="id">
            <div class="mb-3">
              <label for="editSubjectCoefficient" class="form-label">Coefficient</label>
              <input type="number" class="form-control" id="editSubjectCoefficient" name="coefficient" required>
            </div>
            <div class="mb-3">
              <label for="editSubjectGroup" class="form-label">Groupe</label>
              <select class="form-select" id="editSubjectGroup" name="group" required>
                <option value="">Sélectionner un groupe</option>
                {% for group in groups %}
                <option value="{{ group.id }}">{{ group.description }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="mb-3">
              <label for="editSubjectTeacher" class="form-label">Enseignant</label>
              <select class="form-select" id="editSubjectTeacher" name="teacher">
                <option value="">Sélectionner un enseignant</option>
                {% for teacher in teachers %}
                <option value="{{ teacher.id }}">{{ teacher.fullName }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="mb-3">
              <label for="assignTeacherMethod" class="form-label">Méthode d'assignation</label>
              <select class="form-select" id="assignTeacherMethod" name="assignTeacherMethod" required>
                <option value="only_this">Uniquement cette matière</option>
