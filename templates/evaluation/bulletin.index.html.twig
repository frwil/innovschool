        // Fonction pour démarrer le suivi de progression
        function startProgressPolling(taskId) {
            // Arrêter l'intervalle précédent s'il existe
            if (progressInterval) {
                clearInterval(progressInterval);
            }

            pollProgress(taskId);

            // Démarrer un nouvel intervalle
            // progressInterval = setInterval(() => {
            //     pollProgress(taskId);
            // }, 2000); // Interroger toutes les 2 secondes
        }

        // Fonction pour interroger la progression
        function pollProgress(taskId) {
            $.get("{{ path('app_bulletin_progress', {'taskId': 'TASK_ID'}) }}".replace('TASK_ID', taskId))
                .done(function (response) {
                    const progress = response.progress;
                    if (response.status === 'success') {
                        updateProgressBar(progress);

                        if (progress.status === 'completed') {
                            clearInterval(progressInterval);
                            progressInterval = null;
                            handleGenerationSuccess(taskId, progress);
                        } else if (progress.status === 'failed') {
                            clearInterval(progressInterval);
                            progressInterval = null;
                            handleGenerationError(progress.error || 'Erreur lors de la génération');
                        }
                        // Si le statut est 'processing', on continue à interroger
                    } else {
                        clearInterval(progressInterval);
                        progressInterval = null;
                        handleGenerationError(response.message || 'Erreur de réponse du serveur');
                    }
                    if (progress.status !== 'completed' && progress.status !== 'failed') pollProgress(taskId);
                })
                .fail(function (xhr) {
                    console.error('Erreur de suivi:', xhr.responseJSON);
                    clearInterval(progressInterval);
                    progressInterval = null;
                    handleGenerationError('Erreur de connexion lors du suivi de la progression');
                });
        }

        // Fonction pour mettre à jour la barre de progression
        function updateProgressBar(progress) {
            const percentage = progress.percent || progress.percentage || 0;
            const current = progress.current || 0;
            const total = progress.total || 100;
            const message = progress.message || 'Traitement en cours...';

            const $progressBar = $('#progress-bar');
            const $progressText = $progressBar.find('.progress-text');

            $progressBar.css('width', percentage + '%');
            $progressText.text(percentage + '%');

            // Mettre à jour les messages
            $generationMessages.html(`<div><i class="fas fa-info-circle me-2"></i>${message} (${current}/${total})</div>`);

            // Changer la couleur selon la progression
            if (percentage === 100) {
                $progressBar.removeClass('bg-warning').addClass('bg-success');
            }
        }

        // Fonction pour gérer le succès de la génération
        function handleGenerationSuccess(taskId, progress) {
            $progressBarContainer.addClass('generation-success');
            $generationMessages.html(`<div class="text-success"><i class="fas fa-check-circle me-2"></i><strong>Génération terminée avec succès !</strong></div>`);

            // Vérifier le statut du PDF pour obtenir l'URL de téléchargement
            checkPdfStatus(progress, taskId);

            showNotification('Génération des bulletins terminée avec succès !', 'success');
        }

        // Fonction pour vérifier le statut du PDF
        function checkPdfStatus(progress, taskId) {
            if (progress.status === 'completed' && progress.fileUrl) {
                // Configurer le bouton de téléchargement
                $downloadBtn.show()
                    .data('task-id', progress.fileUrl)
                    .off('click')
                    .on('click', function () {
                        window.open("{{ path('app_bulletin_pdf_download', {'fileUrl': 'FILE_URL'}) }}".replace('FILE_URL', progress.fileUrl), '_blank');
                    });

                $generationMessages.html(`<div class="text-success mt-2"><i class="fas fa-download me-2"></i>PDF prêt au téléchargement</div>`);
                $('.alert-spin').hide();
            }
        }

        // Fonction pour gérer les erreurs de génération
        function handleGenerationError(errorMessage) {
            $progressBarContainer.addClass('generation-error');
            $('#progress-bar').removeClass('bg-warning bg-success').addClass('bg-danger');
            $generationMessages.append(`<div class="text-danger"><i class="fas fa-exclamation-triangle me-2"></i><strong>Erreur :</strong> ${errorMessage}</div>`);

            showNotification('Erreur lors de la génération des bulletins: ' + errorMessage, 'error');
        }

        // Gestion du clic sur le bouton de téléchargement
        $downloadBtn.on('click', function () {
            const fileUrl = $(this).data('task-id');
            if (fileUrl) {
                window.open("{{ path('app_bulletin_pdf_download', { 'fileUrl': 'FILE_URL'}) }}".replace('FILE_URL', fileUrl), '_blank');
            }
        });

        // Initialisation des sélecteurs Select2
        if ($.fn.select2) {
            $('.select2').select2({
                theme: 'bootstrap4',
                width: '100%',
                placeholder: function () {
                    return $(this).data('placeholder') || 'Sélectionnez...';
                },
                allowClear: true
            });
        }

        function initTooltips($element) {
            $element.find('[data-bs-toggle="tooltip"]').each(function () {
                // Supprimer l'ancien tooltip s'il existe
                const existingTooltip = bootstrap.Tooltip.getInstance(this);
                if (existingTooltip) {
                    existingTooltip.dispose();
                }

                // Créer un nouveau tooltip
                new bootstrap.Tooltip(this, {
                    html: true,
                    boundary: 'window',
                    trigger: 'hover focus',
                    delay: { show: 100, hide: 100 }
                });
            });
        }

        const $selectAll = $('#select-all-students');
        const $printSelectedBtn = $('#print-selected');
        const $bulkContainer = $('#bulk-actions-container');

        // 1. Gérer la sélection "Tout cocher"
        $(document).on('change', '#select-all-students', function () {
            $('.student-checkbox').prop('checked', $(this).prop('checked'));
            updateBulkButtonState();
        });

        // 2. Gérer la sélection individuelle
        $(document).on('change', '.student-checkbox', function () {
            updateBulkButtonState();
        });

        // 3. Mettre à jour l'état du bouton d'impression
        function updateBulkButtonState() {
            const selectedCount = $('.student-checkbox:checked').length;
            $('#selected-count').text(selectedCount);
            $printSelectedBtn.prop('disabled', selectedCount === 0);

            // Afficher le conteneur si le tableau est visible
            if ($('#students-table').is(':visible')) {
                $bulkContainer.show();
            }
        }

        // 4. Action d'impression de la sélection
        $printSelectedBtn.on('click', function () {
            const selectedIds = [];
            $('.student-checkbox:checked').each(function () {
                selectedIds.push($(this).val());
            });

            const classId = $('#class').val();
            const periodicityId = $('#periodicity').val();
            const bulletinType = $('#bulletin-type').val();
            const templateId = $('#template').val();
            const bulLang = $('#bulLang').val();
            const notePass = $('#notePass').val();

            // Construction de l'URL avec les IDs sélectionnés
            const baseUrl = "{{ path('app_bulletin_frame') }}";
            const params = $.param({
                studentIds: selectedIds, // Envoi du tableau d'IDs
                bulletinType: bulletinType,
                periodicityId: periodicityId,
                classId: classId,
                templateId: templateId,
                bulLang: bulLang,
                notePass: notePass,
                printType: 'full' // Optionnel : pour différencier côté serveur
            });

            window.open(`${baseUrl}?${params}`, '_blank');
        });
    });
</script>
