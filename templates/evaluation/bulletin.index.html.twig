            const templateId = $templateSelect.val();

            if (!classId || !periodicityId || !bulletinType || !templateId) {
                alert('Veuillez sélectionner tous les paramètres requis.');
                return;
            }

            // Vérifier la progression globale des matières
            const globalProgress = parseInt($progressPercentage.text().split('%')[0]);
            if (globalProgress < 100) {
                if (!confirm(`La progression globale des matières n'est qu'à ${globalProgress}%. Voulez-vous quand même générer tous les bulletins PDF ?`)) {
