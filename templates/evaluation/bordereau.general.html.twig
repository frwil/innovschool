                        print-color-adjust: exact !important;
                    }
                    
                    /* Pour les barres de progression colorées en impression */
                    .bg-success { background-color: #d4edda !important; }
                    .bg-info { background-color: #d1ecf1 !important; }
                    .bg-warning { background-color: #fff3cd !important; }
                    .bg-danger { background-color: #f8d7da !important; }
                    
                    /* Réduction de la taille pour les PV cumulés */
                    {% if multiplePeriods %}
                    body {
                        font-size: 9px !important;
                    }
                    
                    table {
                        font-size: 8px !important;
                    }
                    
                    th, td {
                        padding: 4px !important;
                    }
                    
                    .card-body p,
                    .card-body li {
                        font-size: 8px !important;
                        margin-bottom: 2px !important;
                        line-height: 1.2 !important;
                    }
                    
                    .card-header h5 {
                        font-size: 10px !important;
                    }
                    
                    /* Ajustement spécifique pour les cartes en mode cumulé */
                    .col-md-6 {
                        flex: 0 0 48% !important; /* Légèrement moins que 50% pour l'espacement */
                        max-width: 48% !important;
                    }
                    {% else %}
                    /* Pour les non-cumulés, cartes plus grandes */
                    .col-md-6 {
                        flex: 0 0 50% !important;
                        max-width: 50% !important;
                    }
                    {% endif %}
                    
                    /* Éviter les coupures */
                    h1, h2, h3, h4, h5, h6 { 
                        page-break-after: avoid !important;
                    }
                    
                    tr { 
                        page-break-inside: avoid !important; 
