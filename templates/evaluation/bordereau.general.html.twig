                            max-width: 100% !important;
                            margin-bottom: 5px !important;
                        }
                        {% endif %}
                    }
                }
            </style>
        </head>
        <body>
            ${printContents}
        </body>
        </html>
    `);

        printWindow.document.close();

        printWindow.onload = function () {
            printWindow.focus();
            setTimeout(() => {
                printWindow.print();
                printWindow.close();
            }, 500);
        };

        setTimeout(() => {
            document.body.innerHTML = originalContents;
            window.location.reload();
        }, 2000);
    }
</script>
{% endblock %}