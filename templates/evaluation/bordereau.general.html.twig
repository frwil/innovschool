{% extends 'base.up.html.twig' %}

{% block title %}{{ multiplePeriods ? 'Procès Verbal Cumulatif' : (docType =='pv' ? 'Procès Verbal de Notes' :
'Bordereau Général') }}{% endblock %}

{% block body %}
<div class="container mt-4" id="printable-area">
    <h1 class="text-center" style="width:100%;text-align:center">
        {{ multiplePeriods ? 'PROCES VERBAL CUMULATIF DE NOTES' :
        (docType =='pv' ? 'PROCES VERBAL DE NOTES' : 'BORDEREAU GENERAL') }}
    </h1>
    <h2 class="text-center">{{ class.classOccurence.name }}</h2>

    {% if multiplePeriods %}
    <p class="text-center"><strong>Période d'évaluation:</strong> {{ evaluationFrame.name }}</p>
    <p class="text-center"><strong>Périodicité:</strong> {{ evaluationTimeType.name }}</p>
    <p class="text-center"><strong>Sous-périodes:</strong>
        {% for time in evaluationTimes %}
        {{ time.name }}{% if not loop.last %}, {% endif %}
        {% endfor %}
    </p>
    {% else %}
    <p class="text-center"><strong>Période d'évaluation:</strong> {{ evaluationTimes[0].name }}</p>
    <p class="text-center"><strong>Périodicité:</strong> {{ evaluationTimeType.name }}</p>
    {% endif %}

    <!-- Afficher le nombre d'élèves dans chaque catégorie -->
    <div class="alert alert-info">
        <strong>Répartition des élèves:</strong>
        <ul class="mb-0">
            <li>Élèves classés (notes complètes à 100% pour 
                {% if multiplePeriods %}toutes les périodes{% else %}la période{% endif %}): 
                <strong>{{ classifiedStudents|length }}</strong>
            </li>
            <li>Élèves non classés (notes incomplètes): <strong>{{ unclassifiedStudents|length }}</strong></li>
            <li>Total des élèves: <strong>{{ (classifiedStudents|length) + (unclassifiedStudents|length) }}</strong></li>
        </ul>
    </div>

    <!-- TABLEAU 1: ÉLÈVES CLASSÉS (100% de complétion pour toutes les périodes) -->
    {% if classifiedStudents|length > 0 %}
    <h3 class="mt-4 mb-3 text-success">ÉLÈVES CLASSÉS ({{ classifiedStudents|length }} élève(s))</h3>
    
    <!-- Tableau principal (uniquement si une seule période) -->
    {% if not multiplePeriods %}
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th rowspan="2" class="text-center align-middle">#</th>
                <th rowspan="2" class="text-center align-middle">Nom de l'élève</th>
                {% for subjectId, subjectData in classSubjectModules %}
                <th colspan="{{ subjectData.modules|length }}" class="text-center"
                    style="display:{{ docType =='pv' ? 'none' : ''}}">{{ subjectData.name }}</th>
                {% endfor %}
                <th rowspan="2" class="text-center align-middle bg-light">Moyenne Générale</th>
                <th rowspan="2" class="text-center align-middle bg-light">Rang</th>
            </tr>
            <tr>
                {% for subjectId, subjectData in classSubjectModules %}
                {% for module in subjectData.modules|sort((a, b) => a.module.moduleName <=> b.module.moduleName) %}
                    <th class="text-center vertical-text" style="display:{{ docType =='pv' ? 'none' : ''}}">{{ 
                        module.module.moduleName }} ({{ module.moduleNotation}})</th>
                    {% endfor %}
                    {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% set sortedClassifiedStudents = classifiedStudents %}
            {% if docType == 'pv' and includeNotes %}
            {% set sortedClassifiedStudents = classifiedStudents|sort((a, b) =>
            (periodData[evaluationTimes[0].id].studentAverages[b.id] ?? 0) <=>
                (periodData[evaluationTimes[0].id].studentAverages[a.id] ?? 0))
                %}
                {% else %}
                {% set sortedClassifiedStudents = classifiedStudents|sort((a, b) => a.student.fullName <=> b.student.fullName) %}
                    {% endif %}

                    {% for student in sortedClassifiedStudents %}
                    <tr>
                        <td class="text-center">{{ loop.index }}</td>
                        <td>{{ student.student.fullName|upper }}</td>

                        {% for subjectData in classSubjectModules %}
                        {% for module in subjectData.modules|sort((a, b) => a.module.moduleName <=> b.module.moduleName)
                            %}
                            <td class="text-center" style="display:{{ docType =='pv' ? 'none' : ''}}">
                                {% if includeNotes %}
                                {% if periodData[evaluationTimes[0].id].studentNotes[student.id][module.id] is defined %}
                                    {{ (periodData[evaluationTimes[0].id].studentNotes[student.id][module.id])|number_format(2) }}
                                {% else %}
                                    -
                                {% endif %}
                                {% else %}
                                -
                                {% endif %}
                            </td>
                            {% endfor %}
                            {% endfor %}

                            <td class="text-center bg-light fw-bold">
                                {% if includeNotes %}
                                {% if periodData[evaluationTimes[0].id].studentAverages[student.id] is defined %}
                                    {{ (periodData[evaluationTimes[0].id].studentAverages[student.id])|number_format(2) }}
                                {% else %}
                                    -
                                {% endif %}
                                {% else %}
                                -
                                {% endif %}
                            </td>

                            <td class="text-center bg-light fw-bold">
                                {% if includeNotes and periodData[evaluationTimes[0].id].rankedStudents[student.id] is defined %}
                                {{ periodData[evaluationTimes[0].id].rankedStudents[student.id] }}
                                {% else %}
                                -
                                {% endif %}
                            </td>
                    </tr>
                    {% endfor %}

                    {% if includeNotes and periodData[evaluationTimes[0].id].classStats is defined %}
                    <tr class="bg-light fw-bold">
                        <td colspan="2" class="text-center">STATISTIQUES GENERALES (Classés)</td>
                        {% for subjectId, subjectData in classSubjectModules %}
                        {% set subjectStat = periodData[evaluationTimes[0].id].subjectStats[subjectId] %}
                        {% set subjectAverage = subjectStat.count > 0 ? subjectStat.total / subjectStat.count : 0 %}
                        <td colspan="{{ subjectData.modules|length }}" class="text-center"
                            style="display:{{ docType =='pv' ? 'none' : ''}}">
                            Moy: {{ subjectAverage|number_format(2) }}<br>
                            Max: {{ subjectStat.max|number_format(2) }}<br>
                            Min: {{ subjectStat.min|number_format(2) }}
                        </td>
                        {% endfor %}
                        <td class="text-center">
                            {{ periodData[evaluationTimes[0].id].classStats.average|number_format(2) }}
                        </td>
                        <td class="text-center">-</td>
                    </tr>
                    {% endif %}
        </tbody>
    </table>
    {% endif %}

    <!-- Tableau cumulatif (uniquement si plusieurs périodes) -->
    {% if multiplePeriods %}
    <table class="table table-bordered table-striped mt-2">
        <thead>
            <tr>
                <th rowspan="2" class="text-center align-middle">#</th>
                <th rowspan="2" class="text-center align-middle">Nom de l'élève</th>

                {# Colonnes pour chaque sous-période #}
                {% for time in evaluationTimes %}
                <th colspan="1" class="text-center">{{ time.name }}</th>
                {% endfor %}

                {# Colonne pour la moyenne du frame #}
                <th rowspan="2" class="text-center align-middle bg-info text-white">
                    Moy. {{ evaluationFrame.name }}
                </th>

                <th rowspan="2" class="text-center align-middle bg-success text-white">MOYENNE FINALE</th>
                <th rowspan="2" class="text-center align-middle bg-warning">RANG FINAL</th>
            </tr>
            <tr>
                {% for time in evaluationTimes %}
                <th class="text-center">Moy.</th>
                {% endfor %}
                <th class="text-center bg-info text-white">/20</th>
            </tr>
        </thead>
        <tbody>
            {# Trier les élèves classés par moyenne finale #}
            {% set sortedClassifiedStudents = [] %}
            {% if cumulativeData.finalAverages is defined and cumulativeData.finalAverages is not empty %}
            {% for studentId, average in cumulativeData.finalAverages|sort((a, b) => b <=> a) %}
                {% set student = classifiedStudents|filter(s => s.id == studentId)|first %}
                {% if student %}
                {% set sortedClassifiedStudents = sortedClassifiedStudents|merge([student]) %}
                {% endif %}
                {% endfor %}
                {% else %}
                {% set sortedClassifiedStudents = classifiedStudents|sort((a, b) => a.student.fullName <=> b.student.fullName) %}
                    {% endif %}

                    {% for student in sortedClassifiedStudents %}
                    <tr>
                        <td class="text-center">{{ loop.index }}</td>
                        <td>{{ student.student.fullName|upper }}</td>

                        {# Moyennes par sous-période #}
                        {% for time in evaluationTimes %}
                        <td class="text-center">
                            {% if cumulativeData.studentAveragesByPeriod[student.id][time.id] is defined %}
                            {{ cumulativeData.studentAveragesByPeriod[student.id][time.id]|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>
                        {% endfor %}

                        {# Moyenne du frame #}
                        {% set frameId = evaluationTimes[0].evaluationFrame.id %}
                        <td class="text-center bg-light">
                            {% if cumulativeData.periodAverages[student.id][frameId] is defined %}
                            {{ cumulativeData.periodAverages[student.id][frameId]|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>

                        {# Moyenne finale et rang #}
                        <td class="text-center bg-light fw-bold">
                            {% if cumulativeData.finalAverages[student.id] is defined %}
                            {{ cumulativeData.finalAverages[student.id]|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>

                        <td class="text-center bg-light fw-bold">
                            {% if cumulativeData.rankedStudents[student.id] is defined %}
                            {{ cumulativeData.rankedStudents[student.id] }}
                            {% else %}
                            -
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}

                    {# Ligne des moyennes de classe #}
                    <tr class="bg-secondary text-white fw-bold">
                        <td colspan="2" class="text-center">MOYENNES DE CLASSE (Classés)</td>

                        {% for time in evaluationTimes %}
                        <td class="text-center">
                            {% if periodData[time.id].classStats.average is defined %}
                            {{ periodData[time.id].classStats.average|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>
                        {% endfor %}

                        {# Moyenne du frame #}
                        <td class="text-center">
                            {% if cumulativeData.frameClassAverage is defined %}
                            {{ cumulativeData.frameClassAverage|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>

                        <td class="text-center">
                            {% if cumulativeData.finalClassAverage is defined %}
                            {{ cumulativeData.finalClassAverage|number_format(2) }}
                            {% else %}
                            -
                            {% endif %}
                        </td>
                        <td class="text-center">-</td>
                    </tr>
        </tbody>
    </table>
    {% endif %}
    {% else %}
    <div class="alert alert-warning">
        <strong>Aucun élève classé.</strong> Aucun élève n'a un taux de complétion des notes à 100% pour 
        {% if multiplePeriods %}toutes les périodes{% else %}cette période{% endif %}.
    </div>
    {% endif %}

    <!-- TABLEAU 2: ÉLÈVES NON CLASSÉS (<100% de complétion) -->
    {% if unclassifiedStudents|length > 0 %}
    <h3 class="mt-5 mb-3 text-warning">ÉLÈVES NON CLASSÉS ({{ unclassifiedStudents|length }} élève(s))</h3>
    
    <div class="alert alert-warning">
        <strong>Note:</strong> Ces élèves ne sont pas classés car leur taux de complétion des notes est inférieur à 100% 
        {% if multiplePeriods %}pour au moins une période{% else %}pour cette période{% endif %}. 
        Ils n'ont pas de rang.
    </div>
    
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th class="text-center align-middle">#</th>
                <th class="text-center align-middle">Nom de l'élève</th>
                {% if multiplePeriods %}
                    {% for time in evaluationTimes %}
                    <th class="text-center align-middle">Taux {{ time.name }}</th>
                    {% endfor %}
                    <th class="text-center align-middle">Global</th>
                {% else %}
                    <th class="text-center align-middle">Taux de complétion</th>
                    <th class="text-center align-middle">Matières complétées</th>
                {% endif %}
                {% if includeNotes %}
                <th class="text-center align-middle">Moyenne Partielle</th>
                {% endif %}
                <th class="text-center align-middle">Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for student in unclassifiedStudents %}
            <tr>
                <td class="text-center">{{ loop.index }}</td>
                <td>{{ student.student.fullName|upper }}</td>
                
                {% if multiplePeriods %}
                    {% set globalRate = 0 %}
                    {% set periodCount = 0 %}
                    
                    {% for time in evaluationTimes %}
                        <td class="text-center">
                            {% set timeId = time.id %}
                            {% if completionRatesByPeriod[timeId][student.id] is defined %}
                                {% set periodRate = completionRatesByPeriod[timeId][student.id].rate %}
                                {% set globalRate = globalRate + periodRate %}
                                {% set periodCount = periodCount + 1 %}
                                
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar 
                                        {% if periodRate == 100 %}bg-success
                                        {% elseif periodRate >= 75 %}bg-info
                                        {% elseif periodRate >= 50 %}bg-warning
                                        {% else %}bg-danger{% endif %}" 
                                        role="progressbar" 
                                        style="width: {{ periodRate }}%;"
                                        aria-valuenow="{{ periodRate }}" 
                                        aria-valuemin="0" 
                                        aria-valuemax="100">
                                        {{ periodRate|number_format(0) }}%
                                    </div>
                                </div>
                                <small class="text-muted">
                                    {{ completionRatesByPeriod[timeId][student.id].completedSubjects }}/{{ completionRatesByPeriod[timeId][student.id].totalSubjects }}
                                </small>
                            {% else %}
                                <span class="text-danger">-</span>
                            {% endif %}
                        </td>
                    {% endfor %}
                    
                    <td class="text-center">
                        {% set avgRate = periodCount > 0 ? globalRate / periodCount : 0 %}
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar 
                                {% if avgRate == 100 %}bg-success
                                {% elseif avgRate >= 75 %}bg-info
                                {% elseif avgRate >= 50 %}bg-warning
                                {% else %}bg-danger{% endif %}" 
                                role="progressbar" 
                                style="width: {{ avgRate }}%;"
                                aria-valuenow="{{ avgRate }}" 
                                aria-valuemin="0" 
                                aria-valuemax="100">
                                {{ avgRate|number_format(1) }}%
                            </div>
                        </div>
                    </td>
                {% else %}
                    {% set timeId = evaluationTimes[0].id %}
                    <td class="text-center">
                        {% if completionRatesByPeriod[timeId][student.id] is defined %}
                            {% set rate = completionRatesByPeriod[timeId][student.id].rate %}
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar 
                                    {% if rate == 100 %}bg-success
                                    {% elseif rate >= 75 %}bg-info
                                    {% elseif rate >= 50 %}bg-warning
                                    {% else %}bg-danger{% endif %}" 
                                    role="progressbar" 
                                    style="width: {{ rate }}%;"
                                    aria-valuenow="{{ rate }}" 
                                    aria-valuemin="0" 
                                    aria-valuemax="100">
                                    {{ rate|number_format(1) }}%
                                </div>
                            </div>
                        {% else %}
                            <span class="text-danger">Non calculé</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        {% if completionRatesByPeriod[timeId][student.id] is defined %}
                            {{ completionRatesByPeriod[timeId][student.id].completedSubjects }}/{{ completionRatesByPeriod[timeId][student.id].totalSubjects }}
                            matières
                        {% else %}
                            -
                        {% endif %}
                    </td>
                {% endif %}
                
                {% if includeNotes %}
                <td class="text-center">
                    {% if not multiplePeriods and periodData[evaluationTimes[0].id].studentAverages[student.id] is defined %}
                        {{ periodData[evaluationTimes[0].id].studentAverages[student.id]|number_format(2) }}
                    {% elseif multiplePeriods and cumulativeData.finalAverages[student.id] is defined %}
                        {{ cumulativeData.finalAverages[student.id]|number_format(2) }}
                    {% else %}
                        -
                    {% endif %}
                </td>
                {% endif %}
                <td class="text-center">
                    <span class="badge bg-warning">Non classé</span>
                </td>
            </tr>
            
            <!-- Détails des matières incomplètes (optionnel, peut être commenté si trop long) -->
            {% if not multiplePeriods %}
                {% set timeId = evaluationTimes[0].id %}
                {% if completionRatesByPeriod[timeId][student.id] is defined and completionRatesByPeriod[timeId][student.id].subjectDetails is defined %}
                    <tr class="bg-light">
                        <td colspan="2"></td>
                        <td colspan="3">
                            <small>
                                <strong>Détails par matière:</strong><br>
                                {% for subjectDetail in completionRatesByPeriod[timeId][student.id].subjectDetails %}
                                    {% if not subjectDetail.completed %}
                                        <span class="badge bg-danger me-1 mb-1">{{ subjectDetail.name }}: 
                                            {{ subjectDetail.completedModules }}/{{ subjectDetail.moduleCount }} modules
                                        </span>
                                    {% endif %}
                                {% endfor %}
                                {% set completedCount = 0 %}
                                {% for subjectDetail in completionRatesByPeriod[timeId][student.id].subjectDetails %}
                                    {% if subjectDetail.completed %}{% set completedCount = completedCount + 1 %}{% endif %}
                                {% endfor %}
                                <span class="badge bg-success">{{ completedCount }} matières complètes</span>
                            </small>
                        </td>
                        <td></td>
                        {% if includeNotes %}<td></td>{% endif %}
                    </tr>
                {% endif %}
            {% endif %}
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="alert alert-success mt-4">
        <strong>Tous les élèves sont classés!</strong> Tous les élèves ont un taux de complétion des notes à 100% 
        {% if multiplePeriods %}pour toutes les périodes{% else %}pour cette période{% endif %}.
    </div>
    {% endif %}

    <!-- Statistiques générales (uniquement pour les élèves classés) -->
{% if includeNotes and classifiedStudents|length > 0 %}
{% if not multiplePeriods %}
{% set currentData = periodData[evaluationTimes[0].id] %}
{% if currentData.classStats is defined %}
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header text-bg-primary text-white">
                <h5 class="mb-0 text-white">Statistiques Générales (Classés)</h5>
            </div>
            <div class="card-body" style="color:black !important">
                <p><strong>Moyenne de classe:</strong> {{ currentData.classStats.average|number_format(2) }}/20</p>
                <p><strong>Meilleure moyenne:</strong> {{ currentData.classStats.max|number_format(2) }}/20</p>
                <p><strong>Plus basse moyenne:</strong> {{ currentData.classStats.min|number_format(2) }}/20</p>
                <p><strong>Effectif classé:</strong> {{ classifiedStudents|length }} élèves</p>
                <p><strong>Répartition:</strong></p>
                <ul class="list-unstyled">
                    {% if baremes is not null and baremes is not empty %}
                        {# Utilisation des barèmes pour la répartition #}
                        {% set appreciations = {} %}
                        {% for student in classifiedStudents %}
                            {% if currentData.studentAverages[student.id] is defined %}
                                {% set studentAverage = currentData.studentAverages[student.id] %}
                                {% set bareme = get_bareme(studentAverage, baremes) %}
                                {% if bareme %}
                                    {% set appreciation = bareme.evaluationAppreciationValue %}
                                    {% if appreciations[appreciation] is defined %}
                                        {% set appreciations = appreciations|merge({(appreciation): appreciations[appreciation] + 1}) %}
                                    {% else %}
                                        {% set appreciations = appreciations|merge({(appreciation): 1}) %}
                                    {% endif %}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                        
                        {# Afficher la répartition #}
                        {% for appreciation, count in appreciations %}
                            <li>{{ appreciation }}: {{ count }} élève(s)</li>
                        {% endfor %}
                    {% else %}
                        {# Mode par défaut si pas de barèmes #}
                        <li>🎯 Excellent (≥16): {{ currentData.classStats.excellent }} élève(s)</li>
                        <li>⭐ Très bien (14-16): {{ currentData.classStats.tresBien }} élève(s)</li>
                        <li>✓ Bien (12-14): {{ currentData.classStats.bien }} élève(s)</li>
                        <li>↔ Assez bien (10-12): {{ currentData.classStats.assezBien }} élève(s)</li>
                        <li>❌ Insuffisant (<10): {{ currentData.classStats.insuffisant }} élève(s)</li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header text-bg-success text-white">
                <h5 class="mb-0 text-white">Moyennes par Matière (Classés)</h5>
            </div>
            <div class="card-body" style="color:black !important">
                {% for subjectId, subjectData in classSubjectModules %}
                {% set subjectStat = currentData.subjectStats[subjectId] %}
                {% set subjectAverage = subjectStat.count > 0 ? subjectStat.total / subjectStat.count : 0 %}
                <div class="mb-2">
                    <strong>{{ subjectData.name }}:</strong>
                    {% if baremes is not null and baremes is not empty %}
                        {% set bareme = get_bareme(subjectAverage, baremes) %}
                        {% if bareme %}
                            <span class="badge bg-info text-white ms-2">{{ bareme.evaluationAppreciationValue }}</span>
                        {% endif %}
                    {% endif %}
                    <small class="text-muted" style="color:black !important">
                        Moy: {{ subjectAverage|number_format(2) }} |
                        Max: {{ subjectStat.max|number_format(2) }} |
                        Min: {{ subjectStat.min|number_format(2) }}
                    </small>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endif %}
{% endif %}

    <!-- Statistiques générales pour le tableau cumulatif -->
    {% if multiplePeriods and includeNotes and classifiedStudents|length > 0 %}
    {% set cumulativeStats = {
    'average': cumulativeData.finalClassAverage|default(0),
    'max': 0,
    'min': 20,
    'excellent': 0,
    'tresBien': 0,
    'bien': 0,
    'assezBien': 0,
    'insuffisant': 0,
    'count': classifiedStudents|length
    } %}

    {# Calculer les statistiques à partir des moyennes finales #}
    {% for student in classifiedStudents %}
    {% if cumulativeData.finalAverages[student.id] is defined %}
    {% set studentAverage = cumulativeData.finalAverages[student.id] %}

    {# Mise à jour min/max #}
    {% if studentAverage > cumulativeStats.max %}
    {% set cumulativeStats = cumulativeStats|merge({'max': studentAverage}) %}
    {% endif %}
    {% if studentAverage < cumulativeStats.min %} {% set cumulativeStats=cumulativeStats|merge({'min': studentAverage}) %}
        {% endif %} {# Répartition avec barèmes si disponibles #} {% if baremes is not null and baremes is not empty %} {% set bareme=get_bareme(studentAverage, baremes) %} {% if bareme %} {% set
        appreciation=bareme.evaluationAppreciationValue %} {% set key=appreciation|replace({' ': ' _', "'" : '' , 'é' : 'e'
        , 'è' : 'e' , 'ê' : 'e' , 'à' : 'a' , 'â' : 'a' , 'ô' : 'o' , 'û' : 'u' , 'ç' : 'c' })|lower %} {% if
        cumulativeStats[key] is defined %} {% set cumulativeStats=cumulativeStats|merge({(key): cumulativeStats[key] +
        1}) %} {% else %} {% set cumulativeStats=cumulativeStats|merge({(key): 1}) %} {% endif %} {% endif %} {% else %}
        {# Mode par défaut #} {% if studentAverage>= 16 %}
        {% set cumulativeStats = cumulativeStats|merge({'excellent': cumulativeStats.excellent + 1}) %}
        {% elseif studentAverage >= 14 %}
        {% set cumulativeStats = cumulativeStats|merge({'tresBien': cumulativeStats.tresBien + 1}) %}
        {% elseif studentAverage >= 12 %}
        {% set cumulativeStats = cumulativeStats|merge({'bien': cumulativeStats.bien + 1}) %}
        {% elseif studentAverage >= 10 %}
        {% set cumulativeStats = cumulativeStats|merge({'assezBien': cumulativeStats.assezBien + 1}) %}
        {% else %}
        {% set cumulativeStats = cumulativeStats|merge({'insuffisant': cumulativeStats.insuffisant + 1}) %}
        {% endif %}
        {% endif %}
        {% endif %}
        {% endfor %}

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header text-bg-primary text-white">
                        <h5 class="mb-0 text-white">Statistiques Générales Cumulées (Classés)</h5>
                    </div>
                    <div class="card-body" style="color:black !important">
                        <p><strong>Moyenne de classe:</strong> {{ cumulativeStats.average|number_format(2) }}/20</p>
                        <p><strong>Meilleure moyenne:</strong> {{ cumulativeStats.max|number_format(2) }}/20</p>
                        <p><strong>Plus basse moyenne:</strong> {{ cumulativeStats.min|number_format(2) }}/20</p>
                        <p><strong>Effectif classé:</strong> {{ cumulativeStats.count }} élèves</p>
                        <p><strong>Répartition:</strong></p>
                        <ul class="list-unstyled">
                            {% if baremes is not null and baremes is not empty %}
                            {# Afficher la répartition par appréciation #}
                            {% set appreciations = {} %}
                            {% for student in classifiedStudents %}
                            {% if cumulativeData.finalAverages[student.id] is defined %}
                            {% set studentAverage = cumulativeData.finalAverages[student.id] %}
                            {% set bareme = get_bareme(studentAverage, baremes) %}
                            {% if bareme %}
                            {% set appreciation = bareme.evaluationAppreciationValue %}
                            {% if appreciations[appreciation] is defined %}
                            {% set appreciations = appreciations|merge({(appreciation): appreciations[appreciation] + 1}) %}
                            {% else %}
                            {% set appreciations = appreciations|merge({(appreciation): 1}) %}
                            {% endif %}
                            {% endif %}
                            {% endif %}
                            {% endfor %}

                            {% for appreciation, count in appreciations %}
                            <li>{{ appreciation }}: {{ count }} élève(s)</li>
                            {% endfor %}
                            {% else %}
                            {# Mode par défaut #}
                            <li>🎯 Excellent (≥16): {{ cumulativeStats.excellent }} élève(s)</li>
                            <li>⭐ Très bien (14-16): {{ cumulativeStats.tresBien }} élève(s)</li>
                            <li>✓ Bien (12-14): {{ cumulativeStats.bien }} élève(s)</li>
                            <li>↔ Assez bien (10-12): {{ cumulativeStats.assezBien }} élève(s)</li>
                            <li>❌ Insuffisant (<10): {{ cumulativeStats.insuffisant }} élève(s)</li>
                                    {% endif %}
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header text-bg-success text-white">
                        <h5 class="mb-0 text-white">Statistiques par Période (Classés)</h5>
                    </div>
                    <div class="card-body" style="color:black !important">
                        {% for time in evaluationTimes %}
                        {% if periodData[time.id].classStats is defined %}
                        {% set periodStats = periodData[time.id].classStats %}
                        <div class="mb-3">
                            <strong>{{ time.name }}:</strong>
                            {% if baremes is not null and baremes is not empty %}
                            {% set bareme = get_bareme(periodStats.average, baremes) %}
                            {% if bareme %}
                            <span class="badge bg-info text-white ms-2">{{ bareme.evaluationAppreciationValue }}</span>
                            {% endif %}
                            {% endif %}
                            <small class="text-muted" style="color:black !important">
                                Moy: {{ periodStats.average|number_format(2) }} |
                                Max: {{ periodStats.max|number_format(2) }} |
                                Min: {{ periodStats.min|number_format(2) }}
                            </small>
                            <div class="small text-muted mt-1" style="color:black !important">
                                Excellent: {{ periodStats.excellent }} |
                                Très bien: {{ periodStats.tresBien }} |
                                Bien: {{ periodStats.bien }} |
                                Assez bien: {{ periodStats.assezBien }} |
                                Insuffisant: {{ periodStats.insuffisant }}
                            </div>
                        </div>
                        <hr class="my-2">
                        {% endif %}
                        {% endfor %}

                        {# Statistiques des matières pour la dernière période #}
                        {% if evaluationTimes|length > 0 %}
                        {% set lastPeriod = evaluationTimes|last %}
                        {% if periodData[lastPeriod.id].subjectStats is defined %}
                        <div class="mt-3">
                            <strong>Moyennes par matière ({{ lastPeriod.name }}):</strong>
                            {% for subjectId, subjectData in classSubjectModules %}
                            {% set subjectStat = periodData[lastPeriod.id].subjectStats[subjectId] %}
                            {% set subjectAverage = subjectStat.count > 0 ? subjectStat.total / subjectStat.count : 0 %}
                            <div class="mb-2">
                                <small>{{ subjectData.name }}:</small>
                                {% if baremes is not null and baremes is not empty %}
                                {% set bareme = get_bareme(subjectAverage, baremes) %}
                                {% if bareme %}
                                <span class="badge bg-info text-white ms-2">{{ bareme.evaluationAppreciationValue }}</span>
                                {% endif %}
                                {% endif %}
                                <small class="text-muted" style="color:black !important">
                                    Moy: {{ subjectAverage|number_format(2) }} |
                                    Max: {{ subjectStat.max|number_format(2) }} |
                                    Min: {{ subjectStat.min|number_format(2) }}
                                </small>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="text-right mt-4" style="width:100%;text-align:right">
            <p>Fait à ___________________________________, le {{ "now"|date("d/m/Y") }}</p>
            <p>Signature ______________________</p>
        </div>
</div>

<!-- Bouton pour imprimer -->
