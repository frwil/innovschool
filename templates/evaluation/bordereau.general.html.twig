                .bg-info { background-color: #e0f7fa !important; }
                .bg-success { background-color: #e8f5e9 !important; }
                .bg-warning { background-color: #fff3cd !important; }
                .bg-secondary { background-color: #e9ecef !important; }
                
                /* CORRECTION : Classes text-bg-* pour l'impression */
                .text-bg-primary {
                    background-color: #f0f0f0 !important;
                    color: #000 !important;
                    border: 1px solid #ccc !important;
                }
                
                .text-bg-success {
                    background-color: #f5f5f5 !important;
                    color: #000 !important;
                    border: 1px solid #ccc !important;
                }
                
                .text-white { color: #000 !important; } /* Noir pour l'impression */
                .fw-bold { font-weight: bold !important; }
                .align-middle { vertical-align: middle !important; }
                .text-center { text-align: center !important; }
                .text-right { text-align: right !important; }
                .mt-4 { margin-top: 1.5rem !important; }
                .mb-0 { margin-bottom: 0 !important; }
                .mb-2 { margin-bottom: 0.5rem !important; }
                .mb-3 { margin-bottom: 1rem !important; }
                
                /* CORRECTION : Styles pour les cartes de statistiques - IMPORTANT */
                .card {
                    margin-bottom: 1rem;
                    border: 1px solid #ddd !important;
                    border-radius: 4px;
                    page-break-inside: avoid;
                    height: 100%; /* Pour que les cartes aient la même hauteur */
                }
                
                .card-header {
                    padding: 0.75rem 1rem;
