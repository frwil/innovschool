{% extends 'base.up.html.twig' %}

{% block title %}Emploi du temps de
	{{ teacher.fullName }}
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<div class="three">
			<h1>Emploi du temps de
				{{ teacher.fullName }}</h1>
		</div>
		<a href="{{ path('app_timetable_index') }}" class="btn btn-secondary mt-3 btn-lg">Retour à la liste</a>
		<p>
			<strong>Email :</strong>
			{{ teacher.email }}<br>
			<strong>Téléphone :</strong>
			{{ teacher.phone }}
		</p>

		<table id="timetablesTable" class="table table-striped">
			<thead>
				<tr>
					<th>#</th>
					<th>Libellé</th>
					<th>Période</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for timetable in teacher.timetables %}
					<tr>
						<td>{{ loop.index }}</td>
						<td>{{ timetable.label }}</td>
						<td>{{ timetable.period.name }}</td>
						<td>
							<button class="btn btn-primary btn-sm show-timetable-detail" data-timetable="{{ timetable.id }}">
								Détail
							</button>
							<form method="post" action="{{ path('app_timetable_delete', {'id': timetable.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cet emploi du temps ?');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete_timetable_' ~ timetable.id) }}">
								<button type="submit" class="btn btn-danger btn-sm ms-1" title="Supprimer">
									<i class="fa fa-trash"></i>
								</button>
							</form>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		<hr>
		<div id="timetable-detail-block" class="mt-4" style="display: none;">
			<div class="three">
				<h1>Détail de l'emploi du temps</h1>
			</div>
			<form id="class-select-form" method="post">
				<div class="row">
					<div class="col-md-9">
						<input type="hidden" id="selected-timetable-id" name="timetableId">
						<div class="mb-3">
							<label for="class-select" class="form-label">Sélectionner une classe</label>
							<select id="class-select" name="classId" class="form-select select2" required>
								<option value="">Sélectionner</option>
								{% for class in classes %}
									<option value="{{ class.id }}">{{ class.name }}</option>
								{% endfor %}
							</select>
						</div>
					</div>
					<div class="col-md-3" style="padding:3%">
						<button type="submit" class="btn btn-success btn-lg">Charger le tableau</button>
					</div>
				</div>
			</form>
			<div
				id="timetable-grid" class="mt-3"><!-- Le tableau sera chargé ici via AJAX -->
			</div>
		</div>
	</div>
{% endblock %}
{% block javascripts %}
	{{ parent() }}
	<script>
		$(document).ready(function () {
$('#timetablesTable').DataTable();

// Affiche le bloc détail au clic
$('.show-timetable-detail').on('click', function () {
$('#timetable-detail-block').show();
$('#selected-timetable-id').val($(this).data('timetable'));
$('#timetable-grid').html(''); // reset grid
});

// Soumission du formulaire pour charger le tableau
$('#class-select-form').on('submit', function (e) {
e.preventDefault();
var timetableId = $('#selected-timetable-id').val();
var classId = $('#class-select').val();
// AJAX pour charger le tableau (à adapter selon ta route)
$.ajax({
url: "{{ path('app_timetable_grid') }}",
method: "POST",
data: {
timetableId: timetableId,
classId: classId
},
success: function (html) {
$('#timetable-grid').html(html);
}
});
});
});
	</script>
{% endblock %}
