{% extends 'base.html.twig' %}

{% block title %}SchoolPeriod{% endblock %}

{% block body %}
    <h1>SchoolPeriod</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ school_period.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ school_period.name }}</td>
            </tr>
            <tr>
                <th>Enabled</th>
                <td>{{ school_period.enabled ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_school_period_index') }}">back to list</a>

    <a href="{{ path('app_school_period_edit', {'id': school_period.id}) }}">edit</a>

    {{ include('school_period/_delete_form.html.twig') }}
{% endblock %}
