{% extends 'base.up.html.twig' %}
{% block title %}Impression liste élèves inscrits{% endblock %}
{% block body %}
<div class="three">
<h1>Imprimer la liste des élèves inscrits</h1>
</div>
<form method="get" action="{{ path('app_print_students_list') }}" target="_blank" class="mb-4" id="printListForm">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="studyLevel" class="form-label">Niveau d'étude</label>
            <select id="studyLevel" name="studyLevel" class="form-select select2" required>
                <option value="">Sélectionner...</option>
                {% for level in studyLevels %}
                    <option value="{{ level.id }}">{{ level.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label for="classSelect" class="form-label">Classe</label>
            <select id="classSelect" name="classSelect" class="form-select select2" required>
                <option value="">Sélectionner...</option>
                {# À remplir dynamiquement #}
            </select>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Afficher & imprimer la liste</button>
</form>
<div id="studentsListContainer"></div>
<script>
$(function(){
    // Remplissage dynamique des classes selon le niveau choisi
    $('#studyLevel').on('change', function() {
        let levelId = $(this).val();
        if(levelId) {
            $.ajax({
                url: "{{ path('app_classes_by_level') }}",
                method: 'GET',
                data: { level: levelId },
                success: function(data) {
                    let options = '<option value="">Sélectionner...</option>';
                    data.forEach(function(cls) {
                        options += `<option value="${cls.id}">${cls.name}</option>`;
                    });
                    $('#classSelect').html(options);
                }
            });
        } else {
            $('#classSelect').html('<option value="">Sélectionner...</option>');
        }
    });
    // Affichage HTML sans rechargement si format HTML
    $('#printListForm').on('submit', function(e){
        e.preventDefault();
        $.ajax({
            url: $(this).attr('action'),
            method: 'GET',
            data: $(this).serialize(),
            success: function(html){
                $('#studentsListContainer').html(html);
                // Vérifie s'il y a au moins un élève inscrit avant d'ouvrir la boîte d'impression
                if ($('#studentsListContainer table tbody tr').length > 0 &&
                    !$('#studentsListContainer table tbody tr td').first().hasClass('alert-info') &&
                    $('#studentsListContainer table tbody tr').first().find('.alert-info').length === 0 &&
                    $('#studentsListContainer').find('.alert-info').length === 0
                ) {
                    setTimeout(function(){
                        window.print();
                    }, 100);
                }
            },
            error: function(){
                $('#studentsListContainer').html('<div class="alert alert-danger">Erreur lors du chargement de la liste.</div>');
            }
        });
    });
});
</script>
<style>
@media print {
    body * { visibility: hidden !important; }
    #studentsListContainer, #studentsListContainer * {
        visibility: visible !important;
    }
    #studentsListContainer {
        position: absolute !important;
        left: 0; top: 0; width: 100vw; background: #fff;
    }
    /* Bootstrap table styles */
    table.table { border-collapse: collapse !important; width: 100% !important; }
    table.table th, table.table td { border: 1px solid #dee2e6 !important; padding: 0.5rem !important; }
    table.table thead th { background-color: #f8f9fa !important; }
    .text-center { text-align: center !important; }
    .text-end { text-align: right !important; }
    .table-striped tbody tr:nth-of-type(odd) { background-color: #f2f2f2 !important; }
    .table-bordered { border: 1px solid #dee2e6 !important; }
    .display-4 { font-size: 2.5rem !important; font-weight: 300 !important; line-height: 1.2 !important; }
    /* Bootstrap grid system for print */
    .row { display: flex !important; flex-wrap: wrap !important; margin-right: -12px !important; margin-left: -12px !important; }
    .col-md-4, .col-md-6, .col-md-12, .col-4, .col-6, .col-12 {
        position: relative !important;
        width: 100% !important;
        padding-right: 12px !important;
        padding-left: 12px !important;
        box-sizing: border-box !important;
    }
    .col-md-4, .col-4 { flex: 0 0 33.333333% !important; max-width: 33.333333% !important; }
    .col-md-6, .col-6 { flex: 0 0 50% !important; max-width: 50% !important; }
    .col-md-12, .col-12 { flex: 0 0 100% !important; max-width: 100% !important; }
    .mb-3 { margin-bottom: 1rem !important; }
}
</style>
{% endblock %}
