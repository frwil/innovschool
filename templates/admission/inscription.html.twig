{% extends 'base.up.html.twig' %}
{% block title %}Vérification de l'élève{% endblock %}
{% block body %}
<div style="overflow-y:auto">
<form id="wizard">
    <h3>Statut</h3>
    <fieldset>
        <div class="mb-3">
            <label class="form-label">Statut de l'élève :</label>
            <div class="form-group">
                <select name="studentStatus" id="studentStatus" class="form-select select2">
                    <option value="new">Nouvel élève</option>
                    <option value="old">Élève existant</option>
                </select>
            </div>
        </div>
    </fieldset>
    <h3>Choix de l'élève</h3>
    <fieldset>
        <div id="newStudentForm" style="display:none;">
            <div class="row">
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="fullName" class="form-label">Nom complet</label>
                    <input type="text" class="form-control" id="fullName" name="fullName" required>
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="dateOfBirth" class="form-label">Date de naissance</label>
                    <input type="date" class="form-control" id="dateOfBirth" name="dateOfBirth" required>
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="placeOfBirth" class="form-label">Lieu de naissance</label>
                    <input type="text" class="form-control" id="placeOfBirth" name="placeOfBirth" required>
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="gender" class="form-label">Sexe</label>
                    <select class="form-select select2" id="gender" name="gender" required>
                        <option value="">Choisir...</option>
                        <option value="male">Masculin</option>
                        <option value="female">Féminin</option>
                    </select>
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="photo" class="form-label">Photo</label>
                    <input type="file" class="form-control" id="photo" name="photo" accept="image/*">
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="nationalRegistrationNumber" class="form-label">Matricule National</label>
                    <input type="text" class="form-control" id="nationalRegistrationNumber" name="nationalRegistrationNumber">
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="tutorPhone" class="form-label">Numéro de téléphone du tuteur</label>
                    <input type="tel" class="form-control" id="tutorPhone" name="tutorPhone" required pattern="[0-9\s\-\+]{8,15}" placeholder="Ex: 0700000000">
                </div>
                </div>
                <div class="col-md-12 mb-3" id="tutorMatchContainer" style="display:none;">
                    <label class="form-label">Tuteurs existants trouvés :</label>
                    <div id="tutorMatchList"></div>
                </div>
                <div class="col-md-12 mb-3" id="tutorNameContainer" style="display:none;">
                    <label for="tutorName" class="form-label">Nom du tuteur</label>
                    <input type="text" class="form-control" id="tutorName" name="tutorName" required>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="tutorType" class="form-label">Type de tuteur</label>
                    <select class="form-select select2" id="tutorType" name="tutorType" required>
                        <option value="">Choisir...</option>
                        <option value="pere-mere">Père/Mère</option>
                        <option value="frere-soeur">Frère/Sœur</option>
                        <option value="oncle-tante">Oncle/Tante</option>
                    </select>
                </div>
                </div>
                <div class="col-md-6 mb-3">
                <div class="mb-3">
                    <label for="tutorGender" class="form-label">Sexe du tuteur</label>
                    <select class="form-select select2" id="tutorGender" name="tutorGender" required>
                        <option value="">Choisir...</option>
                        <option value="male">Masculin</option>
                        <option value="female">Féminin</option>
                    </select>
                </div>
                </div>
            </div>
        </div>
        <div id="existingStudentTable" style="display:none;">
            <table id="studentsTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Date de naissance</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Rempli dynamiquement via AJAX -->
                </tbody>
            </table>
        </div>
    </fieldset>
    <h3>Choix de la classe</h3>
    <fieldset>
        <div id="classChoiceStep">
            <div class="mb-3">
                <label for="studyLevelSelect" class="form-label">Niveau d'études</label>
                <select class="form-select select2" id="studyLevelSelect" name="studyLevelSelect" required>
                    <option value="">Sélectionner un niveau...</option>
                    {% for section in sections %}
                    <option value="{{ section.id }}">{{ section.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="mb-3">
                <label for="classSelect" class="form-label">Classe</label>
                <select class="form-select select2" id="classSelect" name="classSelect" required>
                    <option value="">Sélectionner une classe...</option>
                    {# À remplir dynamiquement selon le niveau #}
                </select>
            </div>
            <div class="mb-3" id="dateInscriptionContainer">
                <label for="dateInscription" class="form-label">Date D'inscription</label>
                <input type="datetime-local" class="form-control" id="dateInscription" name="dateInscription" required>
            </div>
            <div id="paymentInfoContainer" style="display:none;"></div>
            <div id="paymentTotalContainer" style="display:none;">
                <div class="mt-3">
                    <strong>Total à payer : <span id="paymentTotal">0</span> <span id="paymentCurrency"></span></strong>
                </div>
                <div class="mt-2">
                    <label for="initialPayment" class="form-label">Paiement initial</label>
                    <input type="number" class="form-control" id="initialPayment" name="initialPayment" value="0" min="0" required>
                </div>
            </div>
        </div>
    </fieldset>
</form>
</div>
<!-- Bouton flottant impression liste élèves -->
<a href="{{ path('print_students_list') }}" class="btn btn-primary" id="printListBtn" title="Imprimer la liste des élèves">
    <i class="fa fa-print"></i> Liste élèves
</a>
<style>
#wizard.vertical > .content{
    {# height: 80% !important; #}
}
.wizard, .tabcontrol{
    {# height:80%; #}
}
fieldset{
    overflow-y:auto;
}
#printListBtn {
    position: fixed;
    bottom: 100px;
    left: 20vw;
    z-index: 9999;
    border-radius: 50px;
    padding: 12px 24px;
    font-weight: bold;
    font-style: italic;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
#printListBtn:hover { background: #0056b3; color: #fff; }
</style>
<script>
$(function(){
    // Affichage conditionnel au chargement
    function toggleStepContent() {
        if($('#studentStatus').val()==='old') {
            $('#existingStudentTable').show();
            $('#newStudentForm').hide();
            // Initialiser DataTable si pas déjà fait
            if (!$.fn.DataTable.isDataTable('#studentsTable')) {
                $('#studentsTable').DataTable({
                    destroy: true,
                    ajax: '{{ path("app_students_list") }}',
                    columns: [
                        { data: 'id' },
                        { data: 'fullName' },
                        { data: 'birthDate' },
                        { data: null,
                          render: function(data, type, row) {
                            return !row.isRegistered ? `<input type=\"radio\" name=\"selectedStudent\" data-id=\"${row.id}\" class=\"select-student form-check-input\" value=\"${row.id}\">` :  '<span class="text-muted">Déjà inscrit</span>';
                          }
                        }
                    ],
                    language: {
                        url: "{{asset('i18n/fr-FR.json')}}"
                    },
                    rowCallback: function(row, data) {
                        if(data.isRegistered) {
                            $(row).css({'font-style': 'italic', 'font-weight': 'bold'});
                        }
                    }
                });
            }
        } else {
            $('#existingStudentTable').hide();
            $('#newStudentForm').show();
            if ($.fn.DataTable.isDataTable('#studentsTable')) {
                $('#studentsTable').DataTable().destroy();
            }
        }
    }
    // Initial toggle
    toggleStepContent();
    // Sur changement de statut
    $('#studentStatus').on('change', function(){
        toggleStepContent();
    });
    // Wizard
    $('#wizard').steps({
        headerTag: "h3",
        bodyTag:'fieldset',
        transitionEffect: "slideLeft",
        stepsOrientation: "vertical",
        autoFocus: true,
        onStepChanging: function(event, currentIndex, newIndex) {
            // Si on va en avant (next)
            if (newIndex > currentIndex) {
                if (currentIndex === 0 && newIndex === 1) {
                    // Validation du choix du statut
                    if($('#studentStatus').val() === ''){
                        alert('Veuillez choisir un statut.');
                        return false;
                    }
                    toggleStepContent();
                }
                if(currentIndex === 1 && newIndex === 2) {
                    if($('#studentStatus').val() === 'old') {
                        // Validation sélection élève existant
                        if(!$('input[name="selectedStudent"]:checked').val()){
                            alert('Veuillez sélectionner un élève existant.');
                            return false;
                        }
                    } else {
                        // Vérification si élève existe déjà
                        if($('#wizard').data('student-exists')){
                            alert('Impossible de poursuivre : cet élève existe déjà.');
                            return false;
                        }
                        // Validation des champs requis du formulaire nouvel élève
                        let valid = true;
                        $('#newStudentForm [required]').each(function(){
                            if(!$(this).val()){
                                valid = false;
                                $(this).addClass('is-invalid');
                            } else {
                                $(this).removeClass('is-invalid');
                            }
                        });
                        if(!valid){
                            alert('Veuillez remplir tous les champs obligatoires du nouvel élève.');
                            return false;
                        }
                    }
                }
                if(currentIndex === 2 && newIndex === 3) {
                    // Validation du paiement initial
                    let total = parseFloat($('#paymentTotal').text());
                    let initial = parseFloat($('#initialPayment').val());
                    if(isNaN(initial) || initial < 0) {
                        alert('Le paiement initial doit être un nombre positif.');
                        return false;
                    }
                    if(initial > total) {
                        alert('Le paiement initial ne peut pas dépasser le total à payer.');
                        return false;
                    }
                }
            }
            // Si on va en arrière (previous), ne pas valider
            return true;
        },
        onFinished: function(event, currentIndex) {
            // Vérification qu'il y a au moins une modalité de paiement
            $('a[href="#finish"]').hide();
            if($('#paymentInfoContainer .alert-info').length > 0) {
                alert('Aucune modalité de paiement trouvée pour cette classe. Veuillez choisir une autre classe.');
                $('a[href="#finish"]').show();
                return false;
            }

            if($('#initialPayment').val() == 0) {
                alert('Le paiement initial doit être supérieur à 0');
                $('a[href="#finish"]').show();
                return false;
            }
            // Soumission finale
            if($('#studentStatus').val() === 'old') {
                let selectedId = $('input[name="selectedStudent"]:checked').val();
                let classId = $('#classSelect').val();
                let initialPayment = $('#initialPayment').val();
                let dateInscription = $('#dateInscription').val();
                if(!selectedId || !classId) {
                    alert('Veuillez sélectionner un élève et une classe.');
                    $('a[href="#finish"]').show();
                    return;
                }
                $.ajax({
                    url: "{{ path('app_student_register') }}", // ou une route dédiée si besoin
                    method: 'POST',
                    data: {
                        studentId: selectedId,
                        classSelect: classId,
                        initialPayment: initialPayment,
                        dateInscription:dateInscription,
                    },
                    success: function(response) {
                        if(response.success) {
                            if(response.paymentId && response.studentId && response.classId) {
                                window.open('/receipt?paymentId=' + response.paymentId + '&studentId=' + response.studentId + '&classId=' + response.classId+'&modalType=base', '_blank');
                                window.location.reload();
                            } else {
                                alert('Inscription réussie, mais impossible de générer le reçu (données manquantes).');
                                window.location.reload();
                            }
                        } else {
                            alert('Code : Erreur lors de l\'inscription : ' + (response.message || ''));
                            $('a[href="#finish"]').show();
                        }
                    },
                    error: function(xhr) {
                        alert('Error : Erreur lors de l\'inscription.'+ (xhr.responseJSON && xhr.responseJSON.message ? ' ' + xhr.responseJSON.message : (xhr.status==0 ? '\nErreur de connexion' : 'Erreur code source : ' + xhr.statusText)));
                        $('a[href="#finish"]').show();
                    },
                    complete: function() {
                        $('a[href="#finish"]').show();
                    },
                    fail: function(xhr) {
                        alert('Fail : Erreur lors de l\'inscription.'+ (xhr.responseJSON && xhr.responseJSON.message ? ' ' + xhr.responseJSON.message : (xhr.status==0 ? '\nErreur de connexion' : 'Erreur code source : ' + xhr.statusText)));
                        $('a[href="#finish"]').show();
                    }
                });
            } else {
                // Soumission AJAX du formulaire nouvel élève
                let formData = new FormData();
                formData.append('fullName', $('#fullName').val());
                formData.append('dateOfBirth', $('#dateOfBirth').val());
                formData.append('placeOfBirth', $('#placeOfBirth').val());
                formData.append('gender', $('#gender').val());
                formData.append('registrationNumber', $('#registrationNumber').val() || '');
                formData.append('photo', $('#photo')[0].files[0] || '');
                formData.append('tutorPhone', $('#tutorPhone').val());
                formData.append('tutorName', $('#tutorName').val());
                formData.append('tutorType', $('#tutorType').val());
                formData.append('tutorGender', $('#tutorGender').val());
                formData.append('classSelect', $('#classSelect').val());
                formData.append('initialPayment', $('#initialPayment').val());
                formData.append('dateInscription',$('#dateInscription').val());
                // Ajout d'autres champs si besoin
                $.ajax({
                    url: '{{ path('app_student_register') }}',
                    method: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if(response.success) {
                            if(response.paymentId && response.studentId && response.classId) {
                                window.open('/receipt?paymentId=' + response.paymentId + '&studentId=' + response.studentId + '&classId=' + response.classId+'&modalType=base', '_blank');
                                window.location.reload();
                            } else {
                                alert('Inscription réussie, mais impossible de générer le reçu (données manquantes).');
                                window.location.reload();
                            }
                        } else {
                            alert('Erreur lors de l\'inscription : ' + (response.message || ''));
                            $('a[href="#finish"]').show();
                        }
                    },
                    error: function(xhr) {
                        alert('Erreur lors de l\'inscription.');
                        $('a[href="#finish"]').show();
                    }
                });
            }
        }
    });
    // Recherche AJAX tuteur existant sur saisie du numéro
    $('#tutorPhone').on('input', function() {
        let phone = $(this).val();
        if(phone.length >= 3) {
            $.ajax({
                url: '{{ path('app_parent_search') }}', // Utilisation de la route existante
                method: 'GET',
                data: { phone: phone },
                success: function(data) {
                    if(data.length > 0) {
                        let html = '';
                        // Lors de la génération de la liste, prévoir data-type et data-gender
                        data.forEach(function(tutor, idx) {
                            html += `<div>
                                <input class='tutor-radio' type='radio' name='tutorSelect' id='tutorSelect${idx}' value='${tutor.id}' data-name='${tutor.fullName}' data-type='${tutor.type || ''}' data-gender='${tutor.gender || ''}' data-phone='${tutor.phone}'>
                                <label class='form-check-label' for='tutorSelect${idx}'>${tutor.fullName} (${tutor.phone})</label>
                            </div>`;
                        });
                        $('#tutorMatchList').html(html);
                        $('#tutorMatchContainer').show();
                        $('#tutorNameContainer').show();
                        $('#tutorName').val('');
                    } else {
                        $('#tutorMatchList').html('Aucun tuteur trouvé.');
                        $('#tutorMatchContainer').show();
                        $('#tutorNameContainer').show();
                        $('#tutorName').val('');
                    }
                },
                error: function() {
                    $('#tutorMatchList').html('Erreur lors de la recherche.');
                    $('#tutorMatchContainer').show();
                    $('#tutorNameContainer').show();
                    $('#tutorName').val('');
                }
            });
        } else {
            $('#tutorMatchContainer').hide();
            $('#tutorNameContainer').hide();
            $('#tutorName').val('');
        }
    });
    // Sélection d'un tuteur existant
    $(document).on('change', '.tutor-radio', function() {
        let name = $(this).data('name');
        let type = $(this).data('type') || '';
        let gender = $(this).data('gender') || '';
        let phone = $(this).data('phone');
        $('#tutorName').val(name);
        $('#tutorPhone').val(phone);
        $('#tutorType').val(type).trigger('change');
        $('#tutorGender').val(gender).trigger('change');
    });
    // Vérification AJAX de l'existence de l'élève lors de la saisie du nom
    $('#fullName').on('change', function() {
        let fullName = $(this).val();
        if(fullName.length > 2) {
            $.ajax({
                url: '{{ path('app_student_check') }}', // À créer côté Symfony
                method: 'GET',
                data: { fullName: fullName },
                success: function(data) {
                    if(data.exists) {
                        // Préremplir les champs
                        $('#tutorType').val(data.tutorType || '').trigger('change');
                        $('#dateOfBirth').val(data.dateOfBirth || '');
                        $('#placeOfBirth').val(data.placeOfBirth || '');
                        $('#gender').val(data.gender || '').trigger('change');
                        $('#tutorGender').val(data.tutorGender || '').trigger('change');
                        $('#tutorPhone').val(data.tutorPhone || '').trigger('input');
                        $('#tutorName').val(data.tutorName || '');
                        $('#photo').val(''); // On ne préremplit pas la photo
                        // Bloquer l'étape suivante
                        $('#wizard').data('student-exists', true);
                        // Message flash
                        if($('#studentExistsAlert').length === 0) {
                            $('#newStudentForm').prepend('<div id="studentExistsAlert" class="alert alert-danger">Cet élève existe déjà ! Impossible de poursuivre l\'inscription.</div>');
                        }
                    } else {
                        // Débloquer l'étape suivante
                        $('#wizard').data('student-exists', false);
                        $('#studentExistsAlert').remove();
                    }
                },
                error: function() {
                    $('#studentExistsAlert').remove();
                }
            });
        } else {
            $('#studentExistsAlert').remove();
            $('#wizard').data('student-exists', false);
        }
    });
    
    // Remplissage dynamique des classes selon le niveau choisi
    $('#studyLevelSelect').on('change', function() {
        let levelId = $(this).val();
        if(levelId) {
            $.ajax({
                url: '{{ path('app_classes_by_section') }}', 
                method: 'GET',
                data: { sectionId: levelId },
                success: function(data) {
                    let options = '<option value="">Sélectionner une classe...</option>';
                    data.forEach(function(cls) {
                        options += `<option value="${cls.id}">${cls.name}</option>`;
                    });
                    $('#classSelect').html(options);
                }
            });
        } else {
            $('#classSelect').html('<option value="">Sélectionner une classe...</option>');
        }
    });
    // Affichage des infos de paiement lors de la sélection d'une classe
    $('#classSelect').on('change', function() {
        let classId = $(this).val();
        if(classId) {
            $.ajax({
                url: '{{ path('app_class_payment_modals') }}',
                method: 'GET',
                data: { classId: classId },
                success: function(data) {
                    if(data.length > 0) {
                        let html = '<div class="card"><div class="card-header">Informations de paiement</div><div class="card-body"><ul class="list-group list-group-flush">';
                        let total = 0;
                        let currency = '';
                        data.forEach(function(payment) {
                            html += `<li class="list-group-item">
                                <strong>${payment.label} :</strong> ${payment.amount}
                            </li>`;
                            total += parseFloat(payment.amount);
                            currency = payment.currency;
                        });
                        html += '</ul></div></div>';
                        $('#paymentInfoContainer').html(html).show();
                        $('#paymentTotal').text(total);
                        $('#paymentCurrency').text(currency);
                        $('#paymentTotalContainer').show();
                    } else {
                        $('#paymentInfoContainer').html('<div class="alert alert-info">Aucune modalité de paiement pour cette classe.</div>').show();
                        $('#paymentTotalContainer').hide();
                    }
                },
                error: function() {
                    $('#paymentInfoContainer').html('<div class="alert alert-danger">Erreur lors du chargement des informations de paiement.</div>').show();
                    $('#paymentTotalContainer').hide();
                }
            });
        } else {
            $('#paymentInfoContainer').hide().html('');
            $('#paymentTotalContainer').hide();
        }
    });
    // Suggestions de noms similaires lors de la saisie du nom
    $('#fullName').on('input', function() {
        let val = $(this).val();
        if (val.length >= 5) {
            $.ajax({
                url: '/users/student/similar-names',
                method: 'GET',
                data: { name: val },
                success: function(data) {
                    let $suggest = $('#studentNameSuggestions');
                    if (!$suggest.length) {
                        $('#fullName').after('<div id="studentNameSuggestions" class="alert alert-warning mt-2"></div>');
                        $suggest = $('#studentNameSuggestions');
                    }
                    if (data.length > 0) {
                        let html = '<strong>Noms similaires trouvés :</strong><ul>';
                        data.forEach(function(item) {
                            html += '<li>' + item.name + ' <span class="badge bg-info">' + item.similarity + '%</span></li>';
                        });
                        html += '</ul>';
                        $suggest.html(html).show();
                    } else {
                        $suggest.hide();
                    }
                }
            });
        } else {
            $('#studentNameSuggestions').hide();
        }
    });

    function getCurrentDateTimeLocal() {
    const now = new Date();
    const offset = now.getTimezoneOffset();
    const localDate = new Date(now.getTime() - offset * 60 * 1000);
    return localDate.toISOString().slice(0, 16);
}

$('#dateInscription').val(getCurrentDateTimeLocal());
});

</script>
{% endblock %}

