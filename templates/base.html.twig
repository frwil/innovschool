	{# Notification flottante pour réductions en attente d'approbation #}
	<div id="floating-reduction-notif" style="display:none;position:fixed;bottom:30px;right:30px;z-index:9999;">
		<div id="notif-icon"
			style="background:#ffc107;color:#212529;border-radius:50%;width:48px;height:48px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.15);cursor:pointer;position:relative;">
			<i class="fas fa-percentage fa-lg"></i>
			<span id="notif-badge"
				style="position:absolute;top:2px;right:2px;background:#dc3545;color:#fff;border-radius:50%;font-size:12px;padding:2px 6px;min-width:20px;text-align:center;">0</span>
		</div>
		<div id="notif-details"
			style="display:none;position:absolute;bottom:60px;right:0;max-width:350px;width:350px;background:#fff;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.18);padding:0;overflow:hidden;">
			<div class="card shadow-none mb-0">
				<div class="card-header bg-warning text-dark py-2 px-3">
					<strong>Réductions en attente d'approbation</strong>
				</div>
				<div class="card-body py-2 px-3" id="notif-details-content">
					<div class="text-center text-muted">Aucune réduction en attente.</div>
				</div>
			</div>
		</div>
	</div>
	<script>
		function updateFloatingReductionNotif() {
			$.ajax({
				url: "{{ path('app_pending_admission_reductions_ajax') }}",
				method: 'GET',
				dataType: 'json',
				success: function (data) {
					if (data && data.reductions && data.reductions.length > 0) {
						$('#floating-reduction-notif').show();
						$('#notif-badge').text(data.reductions.length);
						let html = '';
						data.reductions.forEach(function (reduction) {
							html += '<div class="mb-2 border-bottom pb-2">';
							html += '<div><b>Montant :</b> ' + (reduction.amount || 0).toLocaleString('fr-FR') + ' FCFA</div>';
							html += '<div><b>Demandeur :</b> ' + (reduction.requestedBy || '-') + '</div>';
							html += '<div><b>libellé :</b> Demande de réduction pour l\'élève ' + (reduction.student || '-') + '(Classe : ' + (reduction.classe || '-') + ', Modalité : ' + (reduction.modalite || '-') + ')</div>';
							html += '<form method="post" action="' + (reduction.rejectUrl || '') + '" style="display:inline-block" onsubmit="return confirm(\'Confirmer le rejet de cette réduction ?\');">';
							html += '<input type="hidden" name="id" value="' + reduction.id + '">';
							html += '<button type="submit" class="btn btn-sm btn-danger">Rejeter</button>';
							html += '</form>';
							html += '<form method="post" action="' + (reduction.approveUrl || '') + '" style="display:inline-block">';
							html += '<input type="hidden" name="id" value="' + reduction.id + '">';
							html += '<button type="submit" class="btn btn-sm btn-success">Approuver</button>';
							html += '</form>';
							html += '</div>';
						});
						$('#notif-details-content').html(html);
					} else {
						$('#notif-badge').text('0');
						$('#notif-details-content').html('<div class="text-center text-muted">Aucune réduction en attente.</div>');
						$('#floating-reduction-notif').hide();
					}
				},
				error: function () {
					$('#notif-details-content').html('<div class="text-center text-danger">Erreur de chargement.</div>');
				}
			});
		}
		$(function () {
			// Affichage du détail au survol
			$('#notif-icon').hover(
				function () { $('#notif-details').stop(true, true).fadeIn(150); },
				function () { setTimeout(function () { if (!$('#notif-details').is(':hover')) $('#notif-details').fadeOut(150); }, 200); }
			);
			$('#notif-details').mouseleave(function () { $(this).fadeOut(150); });
			// Rafraîchissement toutes les 20 secondes
			//setInterval(updateFloatingReductionNotif, 2000000);
			// Premier chargement au démarrage
			//updateFloatingReductionNotif();
		});
	</script>
