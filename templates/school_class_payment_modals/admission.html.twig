function loadPaymentHistory(studentId, classId, modalType, tableId,btnId) {
    $(`#${btnId}`).prop('disabled',true)
    $.ajax({
        url: '{{ path("app_payment_history_data") }}',
        method: 'GET',
        data: { studentId: studentId, classId: classId, modalType: modalType },
        success: function (data) {
            if($.fn.DataTable.isDataTable(`#${tableId}`)) {
                $(`#${tableId}`).DataTable().destroy(); // Détruire l'instance existante de DataTable
            }
            // Réinitialiser le tableau
            const $table = $(`#${tableId}`).DataTable({columnDefs: [
            { orderable: false, targets: [0,1,2,3,4] } // Désactiver le tri pour la première colonne (cases à cocher)
        ]});
            $table.clear();

            data.forEach(function (payment) {
                $table.row.add([`<input type="checkbox" class="row-checkbox" data-id="${payment.id}" disabled/>`,
                    payment.date,
                    `${payment.amount.toLocaleString('fr-FR', { minimumFractionDigits: 0 })} `,
                    payment.modalLabel,
                    `
                    <button class="btn btn-sm btn-secondary update-payment" data-id="${payment.id}" data-bs-toggle="modal" data-bs-target="#updatePaymentModal">Modifier</button>    
                    <button class="btn btn-sm btn-secondary print-payment" data-id="${payment.id}" data-student-id="${studentId}" data-class-id="${classId}">Imprimer</button>
                        <button class="btn btn-sm btn-danger cancel-payment" data-id="${payment.id}">Annuler</button>
                    `
                ]);
            });

            $table.draw();
            $(`#${btnId}`).prop('disabled',false)
        },
        error: function () {
            $.notify('Une erreur est survenue lors du chargement des paiements.', 'error');
        }
    });

    // Initialiser ou reconfigurer DataTable
    if ($.fn.DataTable.isDataTable(`#${tableId}`)) {
        $(`#${tableId}`).DataTable().destroy(); // Détruire l'instance existante de DataTable
    }
    // Réinitialiser le tableau
    $(`#${tableId}`).DataTable({
        columnDefs: [
            { orderable: false, targets: [0,1,2,3,4] } // Désactiver le tri pour la première colonne (cases à cocher)
        ],
        language: {
            emptyTable: "Aucun paiement trouvé pour cet élève.",
            loadingRecords: "Chargement...",
            processing: "Traitement...",
            search: "Rechercher :",
            lengthMenu: "Afficher _MENU_ entrées",
            info: "Affichage de _START_ à _END_ sur _TOTAL_ entrées",
            infoEmpty: "Aucune entrée disponible",
            infoFiltered: "(filtré à partir de _MAX_ entrées totales)",
            zeroRecords: "Aucun enregistrement correspondant trouvé"
        }
    });
}

function toggleAllChecked(el,tableId,btnId){
    const isChecked = el.checked;
    const $checkboxes = $(`#${tableId} tbody .row-checkbox`);
    $checkboxes.prop('checked', isChecked).closest('tr').toggleClass('selected', isChecked);
    $checkboxes.each(function () {
        const $checkbox = $(this);
        if (isChecked) {
            $checkbox.closest('tr').addClass('selected');
        } else {
            $checkbox.closest('tr').removeClass('selected');
        }
    });
    $(`#${btnId}`).prop('disabled', !isChecked); // Activer ou désactiver le bouton en fonction de l'état de la case à cocher
}

