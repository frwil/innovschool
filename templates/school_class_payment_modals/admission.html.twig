    function loadSubscriptions(studentId, classId) {
            $('#subscriptions-table').off('click', '.cancel-subscription')
            $.ajax({
                url: '{{ path("app_load_subscriptions") }}',
                data: { studentId: studentId, classId: classId },
                success: function (data) {
                    const table = $('#subscriptions-table').DataTable();
                    table.clear();
                    data.forEach(function (subscription) {
                        subscription.amount/=subscription.subscriptionType!=='full' ? 2 : 1; // Diviser le montant par 2 si demi-tarif
                        table.row.add([
                            subscription.modalLabel,
                            subscription.subscriptionType === 'full' ? 'Plein tarif' : 'Demi tarif',
                            subscription.periodicity === 'full' ? 'Plein temps' :
                            subscription.periodicity === 'morning only' ? 'Matin uniquement' : 'Soir uniquement',
                            subscription.amount.toLocaleString('fr-FR', { minimumFractionDigits: 0 }) + ' ',
                            `<button class="btn btn-sm btn-danger cancel-subscription" data-id="${subscription.id}">Annuler</button>`
                        ]);
                    });
                    table.draw();
                    $('#subscriptions-table').off('click', '.cancel-subscription')
                    $('#subscriptions-table').on('click', '.cancel-subscription', function () {
                        const subscriptionId = $(this).data('id');
                        if (confirm('Êtes-vous sûr de vouloir annuler cette souscription ?')) {
                            const cancelType = confirm('Voulez-vous effectuer une annulation définitive ?') ? 'definitive' : 'partial';
                            $.ajax({
                                url: '{{ path("app_cancel_subscription") }}',
                                method: 'POST',
                                data: { subscriptionId: subscriptionId, cancelType: cancelType },
                                success: function () {
                                    $.notify('Souscription annulée avec succès.', 'success');
                                    updateTabs(studentId, classId); // Mettre à jour les onglets après l'annulation
                                },
                                error: function () {
                                    $.notify('Une erreur est survenue lors de l\'annulation de la souscription.', 'error');
                                }
                            });
                        }
                    });
                }
            });
        }

        // Charger les modalités non souscrites
    function loadAvailableModalities(studentId, classId) {
        $.ajax({
            url: '{{ path("app_load_available_modalities") }}',
            data: { studentId: studentId, classId: classId },
            success: function (data) {
                const $modalSelect = $('#subscription-modal');
                $modalSelect.empty().append('<option></option>');
                $('#subscription-student-id').val(studentId)
                $('#subscription-class-id').val(classId)
                // Convertir l'objet en tableau
                const modalitiesArray = Object.values(data);
                modalitiesArray.forEach(function (modal) {
                    $modalSelect.append(`<option value="${modal.id}">${modal.label}</option>`);
                });
                $modalSelect.select2({
                    placeholder:'Sélectionner une modalité',
                    allowClear: true,
                }); // Réinitialiser Select2 après avoir ajouté les options
            }
        });
    }

