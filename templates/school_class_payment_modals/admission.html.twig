    function loadTransportSubscriptions(studentId, classId) {
    $.ajax({
        url: '{{ path("app_load_transport_subscriptions") }}',
        data: { studentId: studentId, classId: classId },
        success: function (data) {
            const table = $('#transport-subscriptions-table').DataTable();
            table.clear();
            data.forEach(function (subscription) {
                subscription.amount /= subscription.subscriptionType !== 'full' ? 2 : 1; // Diviser le montant par 2 si demi-tarif
                table.row.add([
                    subscription.modalLabel,
                    subscription.subscriptionType === 'full' ? 'Plein tarif' : 'Demi tarif',
                    subscription.periodicity === 'full' ? 'Plein temps' :
                    subscription.periodicity === 'morning only' ? 'Matin uniquement' : 'Soir uniquement',
                    subscription.amount.toLocaleString('fr-FR', { minimumFractionDigits: 0 }) + ' ',
                    `<button class="btn btn-sm btn-primary pay-transport-subscription" data-id="${subscription.id}">Faire un paiement</button><button class="btn btn-sm btn-danger cancel-transport-subscription" data-id="${subscription.id}">Annuler</button>`
                ]);
            });
            table.draw();
        }
    });

    $('#print-selected-base').on('click', function () {
        const studentId=$(this).data('student-id');
        const classId=$(this).data('class-id');
        printSelectedRows('base-payments-table',studentId,classId,'base');
    });

    $('#print-selected-additional').on('click', function () {
        const studentId=$(this).data('student-id');
        const classId=$(this).data('class-id');
        printSelectedRows('additional-payments-table',studentId,classId,'additional');
    });

    $('#print-selected-transport').on('click', function () {
        const studentId=$(this).data('student-id');
        const classId=$(this).data('class-id');
        printSelectedRows('transport-payments-table',studentId,classId,'transport');
    });

}
function getCurrentDateTimeLocal() {
    const now = new Date();
    const offset = now.getTimezoneOffset();
    const localDate = new Date(now.getTime() - offset * 60 * 1000);
    return localDate.toISOString().slice(0, 16);
}

    // Fonction pour imprimer les lignes sélectionnées
    function printSelectedRows(tableId,studentId,classId,modalType) {
        const $checkboxes = $(`#${tableId} tbody .row-checkbox:checked`);
        if ($checkboxes.length === 0) {
            alert('Veuillez sélectionner au moins une ligne à imprimer.');
            return;
        }

        // Récupérer les IDs des paiements sélectionnés
        const selectedIds = $checkboxes.map(function () {
            return $(this).data('id');
        }).get();
        
        window.open(`/receipt?paymentId=`+JSON.stringify(selectedIds)+`&studentId=${studentId}&classId=${classId}&modalType=${modalType}`, '_blank');
    }
    
    function reloadAdditionalModalities(studentId, classId) {
        $.ajax({
            url: '{{ path("app_optional_modals") }}',
            data: { classId: classId, studentId: studentId },
            success: function (data) {
                let secondairesHtml = '';
                let totalSecondaires = 0;
                let totalPaiementsSecondaires = 0;
                let totalRestesSecondaires = 0;
                let hasActiveSubscriptions = false;

                // Remplir la liste déroulante des modalités dans le formulaire
                let modalOptionsHtml = '<option></option>';

                data.forEach(function (modal) {
                    if (modal.enabled) {
                        hasActiveSubscriptions = true; // Au moins une modalité est activée
                        const totalPaid = modal.totalPaid || 0; // Paiements effectués pour cette modalité
                        const remaining = modal.amount - totalPaid; // Calcul du reste à payer

                        secondairesHtml += `
                            <div>
                                <strong>${modal.label}</strong>: ${modal.amount.toLocaleString('fr-FR', { minimumFractionDigits: 0 })} 
                                <br>
                                <span class="text-success">Total payé : ${totalPaid.toLocaleString('fr-FR', { minimumFractionDigits: 0 })} </span>
                                <br>
                                <span class="${remaining > 0 ? 'text-danger' : 'text-success'}">Reste à payer : ${remaining.toLocaleString('fr-FR', { minimumFractionDigits: 0 })} </span>
                            </div>
                            <hr>
                        `;

                        modalOptionsHtml += `
                            <option value="${modal.id}">${modal.label} (${modal.amount.toLocaleString('fr-FR', { minimumFractionDigits: 0 })} )</option>
                        `;

                        totalSecondaires += modal.amount;
                        totalPaiementsSecondaires += totalPaid;
                        totalRestesSecondaires += remaining;
                    }
                });

                // Si aucune modalité n'est activée, afficher le message "Aucune souscription"
                if (!hasActiveSubscriptions) {
                    secondairesHtml = `
                        <div class="alert alert-info text-center text-muted">
                            <strong>Aucune souscription</strong>
                        </div>
                    `;
                }

                $('#secondaires-student-id').val(studentId);
                $('#secondaires-class-id').val(classId);

                // Ajouter le contenu des modalités secondaires
                $('#secondaires-list').html(secondairesHtml);

                // Ajouter les options dans la liste déroulante du formulaire
                $('#secondaires-payment-modal').html(modalOptionsHtml);

                // Afficher les totaux globaux pour les modalités additionnelles uniquement si des souscriptions existent
                $('#secondaires-total').text(totalSecondaires.toLocaleString('fr-FR', { minimumFractionDigits: 0 }));
                $('#secondaires-total-payments').text(totalPaiementsSecondaires.toLocaleString('fr-FR', { minimumFractionDigits: 0 }));
                $('#secondaires-total-remaining').text(totalRestesSecondaires.toLocaleString('fr-FR', { minimumFractionDigits: 0 }));
            }
        });
    }

    function validateForm(formId) {
        let isValid = true;
        const form = $(`#${formId}`);
        form.find('input, select').each(function () {
            const field = $(this);
            if (field.prop('required') && !field.val()) {
                field.addClass('is-invalid'); // Ajoute une classe pour indiquer une erreur
                isValid = false;
            } else {
                field.removeClass('is-invalid'); // Supprime la classe si le champ est valide
            }
        });
        return isValid;
    }

